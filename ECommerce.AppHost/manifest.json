{
  "$schema": "https://json.schemastore.org/aspire-8.0.json",
  "resources": {
    "messaging": {
      "type": "container.v0",
      "connectionString": "amqp://guest:{messaging-password-uri-encoded.value}@{messaging.bindings.tcp.host}:{messaging.bindings.tcp.port}",
      "image": "docker.io/library/rabbitmq:4.2",
      "env": {
        "RABBITMQ_DEFAULT_USER": "guest",
        "RABBITMQ_DEFAULT_PASS": "{messaging-password.value}"
      },
      "bindings": {
        "tcp": {
          "scheme": "tcp",
          "protocol": "tcp",
          "transport": "tcp",
          "targetPort": 5672
        }
      }
    },
    "jwt-key": {
      "type": "parameter.v0",
      "value": "{jwt-key.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true,
          "default": { "value": "my-mock-secret" }
        }
      }
    },
    "catalog-api": {
      "type": "project.v0",
      "path": "../Services/Catalog.API/Catalog.API.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{catalog-api.bindings.http.targetPort}",
        "ConnectionStrings__messaging": "{messaging.connectionString}",
        "MESSAGING_HOST": "{messaging.bindings.tcp.host}",
        "MESSAGING_PORT": "{messaging.bindings.tcp.port}",
        "MESSAGING_USERNAME": "guest",
        "MESSAGING_PASSWORD": "{messaging-password.value}",
        "MESSAGING_URI": "amqp://guest:{messaging-password-uri-encoded.value}@{messaging.bindings.tcp.host}:{messaging.bindings.tcp.port}",
        "Jwt__Key": "{jwt-key.value}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http"
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http"
        }
      }
    },
    "discount-api": {
      "type": "project.v0",
      "path": "../Services/Discount.API/Discount.API.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{discount-api.bindings.http.targetPort}",
        "Jwt__Key": "{jwt-key.value}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http"
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http"
        }
      }
    },
    "identity-api": {
      "type": "project.v0",
      "path": "../Services/Identity.API/Identity.API.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{identity-api.bindings.http.targetPort}",
        "Jwt__Key": "{jwt-key.value}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http"
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http"
        }
      }
    },
    "basket-api": {
      "type": "project.v0",
      "path": "../Services/Basket.API/Basket.API.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{basket-api.bindings.http.targetPort}",
        "Jwt__Key": "{jwt-key.value}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http"
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http"
        }
      }
    },
    "payment-api": {
      "type": "project.v0",
      "path": "../Services/Payment.API/Payment.API.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{payment-api.bindings.http.targetPort}",
        "Jwt__Key": "{jwt-key.value}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http"
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http"
        }
      }
    },
    "order-api": {
      "type": "project.v0",
      "path": "../Services/Order.API/Order.API.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{order-api.bindings.http.targetPort}",
        "ConnectionStrings__messaging": "{messaging.connectionString}",
        "MESSAGING_HOST": "{messaging.bindings.tcp.host}",
        "MESSAGING_PORT": "{messaging.bindings.tcp.port}",
        "MESSAGING_USERNAME": "guest",
        "MESSAGING_PASSWORD": "{messaging-password.value}",
        "MESSAGING_URI": "amqp://guest:{messaging-password-uri-encoded.value}@{messaging.bindings.tcp.host}:{messaging.bindings.tcp.port}",
        "PAYMENT_API_HTTP": "{payment-api.bindings.http.url}",
        "services__payment-api__http__0": "{payment-api.bindings.http.url}",
        "PAYMENT_API_HTTPS": "{payment-api.bindings.https.url}",
        "services__payment-api__https__0": "{payment-api.bindings.https.url}",
        "Jwt__Key": "{jwt-key.value}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http"
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http"
        }
      }
    },
    "inventory-api": {
      "type": "project.v0",
      "path": "../Services/Inventory.API/Inventory.API.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{inventory-api.bindings.http.targetPort}",
        "ConnectionStrings__messaging": "{messaging.connectionString}",
        "MESSAGING_HOST": "{messaging.bindings.tcp.host}",
        "MESSAGING_PORT": "{messaging.bindings.tcp.port}",
        "MESSAGING_USERNAME": "guest",
        "MESSAGING_PASSWORD": "{messaging-password.value}",
        "MESSAGING_URI": "amqp://guest:{messaging-password-uri-encoded.value}@{messaging.bindings.tcp.host}:{messaging.bindings.tcp.port}",
        "Jwt__Key": "{jwt-key.value}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http"
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http"
        }
      }
    },
    "gateway": {
      "type": "project.v0",
      "path": "../YarpGateway.API/YarpGateway.API.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{gateway.bindings.http.targetPort}",
        "CATALOG_API_HTTP": "{catalog-api.bindings.http.url}",
        "services__catalog-api__http__0": "{catalog-api.bindings.http.url}",
        "CATALOG_API_HTTPS": "{catalog-api.bindings.https.url}",
        "services__catalog-api__https__0": "{catalog-api.bindings.https.url}",
        "DISCOUNT_API_HTTP": "{discount-api.bindings.http.url}",
        "services__discount-api__http__0": "{discount-api.bindings.http.url}",
        "DISCOUNT_API_HTTPS": "{discount-api.bindings.https.url}",
        "services__discount-api__https__0": "{discount-api.bindings.https.url}",
        "BASKET_API_HTTP": "{basket-api.bindings.http.url}",
        "services__basket-api__http__0": "{basket-api.bindings.http.url}",
        "BASKET_API_HTTPS": "{basket-api.bindings.https.url}",
        "services__basket-api__https__0": "{basket-api.bindings.https.url}",
        "IDENTITY_API_HTTP": "{identity-api.bindings.http.url}",
        "services__identity-api__http__0": "{identity-api.bindings.http.url}",
        "IDENTITY_API_HTTPS": "{identity-api.bindings.https.url}",
        "services__identity-api__https__0": "{identity-api.bindings.https.url}",
        "ORDER_API_HTTP": "{order-api.bindings.http.url}",
        "services__order-api__http__0": "{order-api.bindings.http.url}",
        "ORDER_API_HTTPS": "{order-api.bindings.https.url}",
        "services__order-api__https__0": "{order-api.bindings.https.url}",
        "PAYMENT_API_HTTP": "{payment-api.bindings.http.url}",
        "services__payment-api__http__0": "{payment-api.bindings.http.url}",
        "PAYMENT_API_HTTPS": "{payment-api.bindings.https.url}",
        "services__payment-api__https__0": "{payment-api.bindings.https.url}",
        "INVENTORY_API_HTTP": "{inventory-api.bindings.http.url}",
        "services__inventory-api__http__0": "{inventory-api.bindings.http.url}",
        "INVENTORY_API_HTTPS": "{inventory-api.bindings.https.url}",
        "services__inventory-api__https__0": "{inventory-api.bindings.https.url}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http"
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http"
        }
      }
    },
    "web-ui": {
      "type": "project.v0",
      "path": "../WebUI/WebUI.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EXCEPTION_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_EMIT_EVENT_LOG_ATTRIBUTES": "true",
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{web-ui.bindings.http.targetPort}",
        "GATEWAY_HTTP": "{gateway.bindings.http.url}",
        "services__gateway__http__0": "{gateway.bindings.http.url}",
        "GATEWAY_HTTPS": "{gateway.bindings.https.url}",
        "services__gateway__https__0": "{gateway.bindings.https.url}",
        "CATALOG_API_HTTP": "{catalog-api.bindings.http.url}",
        "services__catalog-api__http__0": "{catalog-api.bindings.http.url}",
        "CATALOG_API_HTTPS": "{catalog-api.bindings.https.url}",
        "services__catalog-api__https__0": "{catalog-api.bindings.https.url}",
        "BASKET_API_HTTP": "{basket-api.bindings.http.url}",
        "services__basket-api__http__0": "{basket-api.bindings.http.url}",
        "BASKET_API_HTTPS": "{basket-api.bindings.https.url}",
        "services__basket-api__https__0": "{basket-api.bindings.https.url}",
        "ORDER_API_HTTP": "{order-api.bindings.http.url}",
        "services__order-api__http__0": "{order-api.bindings.http.url}",
        "ORDER_API_HTTPS": "{order-api.bindings.https.url}",
        "services__order-api__https__0": "{order-api.bindings.https.url}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http"
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http"
        }
      }
    },
    "messaging-password": {
      "type": "parameter.v0",
      "value": "{messaging-password.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true,
          "default": {
            "generate": {
              "minLength": 22,
              "special": false
            }
          }
        }
      }
    },
    "messaging-password-uri-encoded": {
      "type": "annotated.string",
      "value": "{messaging-password.value}",
      "filter": "uri"
    }
  }
}
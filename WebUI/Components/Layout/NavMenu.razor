@using Blazored.LocalStorage
@using Common.DTOs
@implements IDisposable
@inject ILocalStorageService LocalStore
@inject NavigationManager Nav
@inject BasketService BasketService

<!-- Announcement Bar -->
<div class="announcement-bar">
    <span>İlk siparişinizde <strong>%20 indirim</strong> fırsatını kaçırmayın! &nbsp;<a href="/register">Şimdi Kayıt Ol →</a></span>
</div>

<nav class="navbar navbar-expand-lg shop-nav sticky-top">
    <div class="container py-2">
        <a class="navbar-brand brand-bold" href="">E-TİCARET</a>

        <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <i class="bi bi-list fs-2"></i>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-5">
                <li class="nav-item">
                    <NavLink class="nav-link nav-link-bold" href="" Match="NavLinkMatch.All">Yeni Gelenler</NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link nav-link-bold" href="products">Koleksiyon</NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link nav-link-bold sale-link" href="products?filter=discounted">İndirimli</NavLink>
                </li>
            </ul>

            <div class="d-flex align-items-center gap-3">
                <div class="search-bar-minimal d-none d-md-flex">
                    <i class="bi bi-search text-muted"></i>
                    <input type="text" placeholder="Ürün ara..." />
                </div>

                <NavLink class="nav-icon-link position-relative" href="basket">
                    <i class="bi bi-bag fs-5"></i>
                    @if (basketItemCount > 0)
                    {
                        <span class="basket-badge">@basketItemCount</span>
                    }
                </NavLink>

                <AuthorizeView>
                    <Authorized>
                        <div class="dropdown">
                            <button class="btn user-btn-minimal dropdown-toggle px-0" type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle fs-5"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end" style="min-width:220px;">
                                <li class="px-3 py-2 border-bottom">
                                    <span class="d-flex align-items-center gap-2">
                                        <div class="user-avatar-sm"><i class="bi bi-person-fill"></i></div>
                                        <div>
                                            <div class="fw-bold small" style="color:#000;">Hesabım</div>
                                            <div class="text-muted" style="font-size:0.72rem;">Üye</div>
                                        </div>
                                    </span>
                                </li>
                                <li><NavLink class="dropdown-item py-2" href="profile"><i class="bi bi-person me-2 text-muted"></i>Profilim</NavLink></li>
                                <li><NavLink class="dropdown-item py-2" href="my-orders"><i class="bi bi-box-seam me-2 text-muted"></i>Siparişlerim</NavLink></li>
                                <li><NavLink class="dropdown-item py-2" href="basket"><i class="bi bi-bag me-2 text-muted"></i>Sepetim</NavLink></li>
                                <li><NavLink class="dropdown-item py-2" href="products?filter=discounted"><i class="bi bi-tag me-2 text-muted"></i>Kampanyalar</NavLink></li>
                                <AuthorizeView Roles="Admin" Context="adminContext">
                                    <li><hr class="dropdown-divider mx-2"></li>
                                    <li class="px-3 py-1"><span class="text-muted" style="font-size:0.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em;">Yönetim</span></li>
                                    <li><NavLink class="dropdown-item py-2 fw-semibold" href="admin/dashboard"><i class="bi bi-speedometer2 me-2 text-muted"></i>Dashboard</NavLink></li>
                                    <li><NavLink class="dropdown-item py-2" href="admin/products"><i class="bi bi-box me-2 text-muted"></i>Ürünler</NavLink></li>
                                    <li><NavLink class="dropdown-item py-2" href="admin/orders"><i class="bi bi-receipt me-2 text-muted"></i>Siparişler</NavLink></li>
                                    <li><NavLink class="dropdown-item py-2" href="admin/discounts"><i class="bi bi-percent me-2 text-muted"></i>İndirimler</NavLink></li>
                                    <li><NavLink class="dropdown-item py-2" href="admin/inventory"><i class="bi bi-archive me-2 text-muted"></i>Stok</NavLink></li>
                                </AuthorizeView>
                                <li><hr class="dropdown-divider mx-2"></li>
                                <li><a class="dropdown-item py-2 text-danger" @onclick="Logout" href="javascript:void(0)"><i class="bi bi-box-arrow-right me-2"></i>Çıkış Yap</a></li>
                            </ul>
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <NavLink class="nav-link nav-link-bold" href="login">Giriş</NavLink>
                        <NavLink class="btn btn-primary px-4 py-2" href="register">Kayıt Ol</NavLink>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </div>
</nav>

<style>
    .announcement-bar {
        background: #000;
        color: #fff;
        text-align: center;
        padding: 10px 16px;
        font-size: 0.875rem;
        font-weight: 400;
    }
    .announcement-bar strong { font-weight: 700; }
    .announcement-bar a {
        color: #fff;
        font-weight: 700;
        text-decoration: underline;
        text-underline-offset: 3px;
    }
    .announcement-bar a:hover { opacity: 0.8; }

    .shop-nav {
        background: #FFFFFF !important;
        border-bottom: 1px solid var(--border-color);
        z-index: 1050;
    }

    .brand-bold {
        font-weight: 900;
        font-size: 1.6rem;
        letter-spacing: -1.5px;
        color: #000 !important;
        text-decoration: none;
    }

    .nav-link-bold {
        color: #000 !important;
        font-weight: 600;
        font-size: 0.9rem;
        padding: 0.4rem 0.75rem !important;
        border-radius: 8px;
        transition: background 0.2s;
    }
    .nav-link-bold:hover { background: #F0F0F0; }
    .nav-link-bold.active { font-weight: 800; }

    .sale-link { color: #e53935 !important; }

    .search-bar-minimal {
        background: #F0F0F0;
        border-radius: 50px;
        padding: 8px 18px;
        display: flex;
        align-items: center;
        gap: 8px;
        width: 260px;
        border: 1.5px solid transparent;
        transition: border-color 0.2s;
    }
    .search-bar-minimal:focus-within { border-color: #000; background: #fff; }
    .search-bar-minimal input {
        border: none;
        background: transparent;
        font-size: 0.875rem;
        width: 100%;
        outline: none;
        color: #000;
        font-family: 'Inter', sans-serif;
    }

    .nav-icon-link {
        color: #000;
        transition: opacity 0.2s;
        text-decoration: none;
        display: flex;
        align-items: center;
    }
    .nav-icon-link:hover { opacity: 0.6; color: #000; }

    .basket-badge {
        position: absolute;
        top: -6px; right: -8px;
        background: #000; color: #fff;
        font-size: 0.6rem; font-weight: 900;
        width: 17px; height: 17px;
        display: flex; align-items: center; justify-content: center;
        border-radius: 50%;
    }

    .user-btn-minimal {
        background: transparent;
        border: none;
        color: #000;
        display: flex; align-items: center;
    }
    .user-btn-minimal::after { display: none; }
    .user-btn-minimal:hover { color: #555; }

    .user-avatar-sm {
        width: 36px; height: 36px;
        background: #000; color: #fff;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .dropdown-menu li .dropdown-item {
        font-size: 0.875rem;
        color: #000;
    }
</style>

@code {
    [Inject] private WebUI.Providers.CustomAuthStateProvider AuthProvider { get; set; } = default!;

    private int basketItemCount = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            BasketService.OnBasketChanged += HandleBasketChanged;
            await LoadBasketCount();
        }
    }

    private void HandleBasketChanged(int count)
    {
        basketItemCount = count;
        InvokeAsync(StateHasChanged);
    }

    private async Task LoadBasketCount()
    {
        try
        {
            var token = await LocalStore.GetItemAsync<string>("authToken");
            var userName = await LocalStore.GetItemAsync<string>("userName");
            if (string.IsNullOrEmpty(userName))
                userName = await LocalStore.GetItemAsync<string>("guestId");
            if (!string.IsNullOrEmpty(userName))
            {
                var basket = await BasketService.GetBasket(token ?? "", userName);
                basketItemCount = basket?.Items?.Sum(x => x.Quantity) ?? 0;
                StateHasChanged();
            }
        }
        catch { basketItemCount = 0; }
    }

    private async Task Logout()
    {
        await LocalStore.RemoveItemAsync("authToken");
        await LocalStore.RemoveItemAsync("userName");
        await LocalStore.RemoveItemAsync("userRole");
        basketItemCount = 0;
        AuthProvider.NotifyUserLogout();
        Nav.NavigateTo("/");
    }

    public void Dispose()
    {
        BasketService.OnBasketChanged -= HandleBasketChanged;
    }
}

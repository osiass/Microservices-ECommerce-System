@using Blazored.LocalStorage
@inject ILocalStorageService LocalStore
@inject NavigationManager Nav

<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-lg py-3 sticky-top">
    <div class="container">
        <a class="navbar-brand fw-bold fs-3" href="">
            <i class="bi bi-cart4 text-primary me-2"></i>E-Ticaret
        </a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <NavLink class="nav-link px-3" href="" Match="NavLinkMatch.All">
                        Ana Sayfa
                    </NavLink>
                </li>
            </ul>
            
            <div class="d-flex align-items-center gap-3">
                <NavLink class="nav-link text-light px-2 position-relative" href="basket">
                    <i class="bi bi-cart-fill fs-5"></i>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">
                        !
                    </span>
                </NavLink>

                @if (string.IsNullOrEmpty(token))
                {
                    <NavLink class="btn btn-outline-light px-4" href="login">Giriş Yap</NavLink>
                    <NavLink class="btn btn-primary px-4" href="register">Kayıt Ol</NavLink>
                }
                else
                {
                    <div class="dropdown">
                        <button class="btn btn-dark dropdown-toggle px-3" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle me-2"></i>@userName
                        </button>
                        <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end shadow">
                            <li><NavLink class="dropdown-item" href="my-orders"><i class="bi bi-clock-history me-2"></i>Siparişlerim</NavLink></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" @onclick="Logout" href="javascript:void(0)"><i class="bi bi-box-arrow-right me-2"></i>Çıkış Yap</a></li>
                        </ul>
                    </div>
                }
            </div>
        </div>
    </div>
</nav>

@code {
    private string? token;
    private string? userName;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            token = await LocalStore.GetItemAsync<string>("authToken");
            userName = await LocalStore.GetItemAsync<string>("userName");
            StateHasChanged();
        }
    }

    private async Task Logout()
    {
        await LocalStore.RemoveItemAsync("authToken");
        await LocalStore.RemoveItemAsync("userName");
        Nav.NavigateTo("/", forceLoad: true);
    }
}


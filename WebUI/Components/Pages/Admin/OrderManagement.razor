@page "/admin/orders"
@using Common.DTOs
@using Microsoft.AspNetCore.Authorization
@using WebUI.Services
@inject OrderService OrderService
@inject Blazored.LocalStorage.ILocalStorageService LocalStore
@attribute [Authorize(Roles = "Admin")]

<div class="container-fluid py-4 px-4 pb-5">
    <div class="admin-header">
        <div>
            <h2 class="admin-title"><i class="bi bi-bag-check me-2 text-primary"></i> Sipariş Yönetimi</h2>
            <p class="admin-subtitle text-white-50">Sistemdeki tüm siparişlerin durumunu ve detaylarını yönetin.</p>
        </div>
        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-10 rounded-pill px-4 py-2 fw-bold">
            @orders.Count Toplam Sipariş
        </span>
    </div>

    @if (isLoading)
    {
        <div class="admin-card border-0 p-0 overflow-hidden">
            @for (int i = 0; i < 6; i++)
            {
                <div class="skeleton skeleton-row m-0 w-100" style="border-radius: 0; opacity: 0.5;"></div>
            }
        </div>
    }
    else
    {
        <div class="admin-card border-0 p-0 overflow-hidden">
            <div class="table-responsive text-nowrap">
                <table class="table table-dark table-hover align-middle mb-0">
                    <thead class="text-white-50 small text-uppercase" style="background: rgba(255,255,255,0.02);">
                        <tr class="border-bottom border-white border-opacity-10">
                            <th class="ps-4 py-3 border-0">Sipariş ID</th>
                            <th class="py-3 border-0">Müşteri</th>
                            <th class="py-3 border-0">Tarih</th>
                            <th class="py-3 border-0">Toplam Tutar</th>
                            <th class="text-center py-3 border-0">Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (orders == null || !orders.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-white-50">
                                    <i class="bi bi-inbox fs-1 d-block mb-3 opacity-25"></i>
                                    Henüz sipariş bulunmuyor.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var order in orders)
                            {
                                <tr class="border-bottom border-white border-opacity-5">
                                    <td class="ps-4">
                                        <code class="text-primary smaller bg-primary bg-opacity-10 px-2 py-1 rounded">#@order.Id.ToString().PadLeft(5, '0')</code>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="bg-primary bg-opacity-25 rounded-circle me-3 d-flex align-items-center justify-content-center text-primary fw-bold" style="width: 36px; height: 36px; font-size: 0.85rem; border: 1px solid rgba(99, 102, 241, 0.2);">
                                                @order.UserName.ToUpper().Substring(0, 1)
                                            </div>
                                            <span class="fw-semibold">@order.UserName</span>
                                        </div>
                                    </td>
                                    <td class="text-white-50 small">@order.CreatedDate.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                                    <td class="fw-bold text-primary">@order.TotalPrice.ToString("C")</td>
                                    <td class="text-center pe-4">
                                        <select class="admin-select w-auto" 
                                                @onchange='(e) => UpdateStatus(order, e)'>
                                            @foreach (var status in Enum.GetValues<OrderStatus>())
                                            {
                                                <option value="@status" selected="@(status == order.Status)">@status.ToStatusText()</option>
                                            }
                                        </select>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<OrderDto> orders = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        isLoading = true;
        try 
        {
            var token = await LocalStore.GetItemAsync<string>("authToken");
            orders = await OrderService.GetAllOrders(token ?? "");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[OrderManagement] Sipariş yükleme hatası: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task UpdateStatus(OrderDto order, ChangeEventArgs e)
    {
        if (Enum.TryParse<OrderStatus>(e.Value?.ToString(), out var newStatus))
        {
            var token = await LocalStore.GetItemAsync<string>("authToken");
            var success = await OrderService.UpdateOrderStatus(token ?? "", order.Id, newStatus);
            if (success)
            {
                order.Status = newStatus;
                // ToastService.Notify("Durum güncellendi", ToastLevel.Success);
            }
        }
    }
}

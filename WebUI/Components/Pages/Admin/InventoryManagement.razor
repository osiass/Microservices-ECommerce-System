@page "/admin/inventory"
@using WebUI.Services
@using Common.DTOs
@inject InventoryService InventoryService
@inject CatalogService CatalogService
@inject ToastService ToastService
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]

<div class="container-fluid py-4 min-vh-100">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-white mb-1">Envanter Yönetimi </h2>
            <p class="text-white-50 small mb-0">Ürün stok seviyelerini gerçek zamanlı izleyin ve yönetin</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary border-2 px-4 py-2" @onclick="LoadData" style="border-radius: 12px;">
                <i class="bi bi-arrow-clockwise me-2"></i> Yenile
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="row g-4">
            @for (int i = 0; i < 6; i++)
            {
                <div class="col-md-4">
                    <div class="admin-card p-4" style="height: 180px; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 20px;">
                        <div class="skeleton-shimmer h-100 w-100 rounded-3"></div>
                    </div>
                </div>
            }
        </div>
    }
    else if (!stocks.Any())
    {
        <div class="admin-card text-center p-5" style="background: rgba(255,255,255,0.02); border: 1px dashed rgba(255,255,255,0.1); border-radius: 24px;">
            <div class="bg-warning bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px;">
                <i class="bi bi-box-seam text-warning fs-1"></i>
            </div>
            <h4 class="text-white fw-bold">Stok Bilgisi Bulunamadı</h4>
            <p class="text-white-50 mx-auto" style="max-width: 400px;">Henüz hiçbir ürün için stok kaydı oluşturulmamış. Ürün ekledikçe stoklar burada görünecektir.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var stock in stocks)
            {
                var product = products.FirstOrDefault(p => p.Id.ToString() == stock.ProductId);
                <div class="col-md-4">
                    <div class="admin-card border-0 p-4 h-100 animate__animated animate__fadeIn" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08) !important; backdrop-filter: blur(20px); border-radius: 24px;">
                        <div class="d-flex align-items-center mb-3">
                            <div class="product-img-mini me-3">
                                @if (product != null)
                                {
                                    <img src="@CatalogService.GetFullImageUrl(product.ImageUrl)" class="rounded-pill" style="width: 50px; height: 50px; object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="bg-white bg-opacity-10 rounded-pill d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                        <i class="bi bi-question-lg text-white-50"></i>
                                    </div>
                                }
                            </div>
                            <div>
                                <h6 class="fw-bold text-white mb-0 text-truncate" style="max-width: 180px;">@(product?.Name ?? "Bilinmeyen Ürün")</h6>
                                <span class="text-white-50 smallest">ID: @stock.ProductId</span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-end mt-4">
                            <div>
                                <span class="text-white-50 small d-block mb-1">Mevcut Stok</span>
                                <h2 class="fw-black mb-0 @(stock.Quantity < 10 ? "text-danger-glow" : "text-primary-glow")">@stock.Quantity</h2>
                            </div>
                            <div class="text-end">
                                <span class="badge @(stock.Quantity > 0 ? "bg-success" : "bg-danger") bg-opacity-10 @(stock.Quantity > 0 ? "text-success" : "text-danger") px-3 py-2" style="border-radius: 8px;">
                                    @(stock.Quantity > 0 ? "STOKTA VAR" : "TÜKENDİ")
                                </span>
                            </div>
                        </div>

                        @if (stock.Quantity < 10 && stock.Quantity > 0)
                        {
                            <div class="mt-3 p-2 bg-warning bg-opacity-10 text-warning smaller rounded-3 border border-warning border-opacity-10 text-center animate-pulse">
                                <i class="bi bi-exclamation-triangle-fill me-1"></i> Kritik Seviye!
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .skeleton-shimmer {
        background: linear-gradient(90deg, rgba(255,255,255,0.03) 25%, rgba(255,255,255,0.08) 50%, rgba(255,255,255,0.03) 75%);
        background-size: 200% 100%;
        animation: shimmer 1.5s infinite linear;
    }
    @@keyframes shimmer {
        from { background-position: -200% 0; }
        to { background-position: 200% 0; }
    }
    .text-danger-glow {
        color: #ff4d4d;
        text-shadow: 0 0 10px rgba(255, 77, 77, 0.4);
    }
    .text-primary-glow {
        color: var(--primary-glow);
        text-shadow: 0 0 10px rgba(99, 102, 241, 0.4);
    }
</style>

@code {
    private List<StockDto> stocks = new();
    private List<ProductDto> products = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try 
        {
            // İki veriyi paralel çek
            var stocksTask = InventoryService.GetStocks();
            var productsTask = CatalogService.GetProducts();
            
            await Task.WhenAll(stocksTask, productsTask);
            
            stocks = await stocksTask;
            products = await productsTask;
        } 
        finally 
        {
            isLoading = false;
        }
    }

}

@page "/register"
@using WebUI.Services
@using Common.DTOs
@inject AuthService AuthService
@inject NavigationManager Nav
@inject ToastService ToastService

<div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="col-md-5 col-lg-4">
        <div class="admin-card border-0 p-4 p-md-5" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08) !important; backdrop-filter: blur(20px); border-radius: 30px;">
            <div class="text-center mb-4">
                <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                    <i class="bi bi-person-plus text-success fs-2"></i>
                </div>
                <h2 class="fw-bold text-white mb-1">Hesap Oluştur</h2>
                <p class="text-white-50 opacity-75 small">Hemen saniyeler içinde katılın</p>
            </div>

            <EditForm Model="model" OnValidSubmit="HandleRegister">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label class="form-label text-white-50 small fw-bold text-uppercase opacity-75 ms-1 mb-2">Kullanıcı Adı</label>
                    <div class="position-relative">
                        <i class="bi bi-person position-absolute top-50 start-0 translate-middle-y ms-3 text-white-50 opacity-50"></i>
                        <InputText @bind-Value="model.UserName" class="form-control ps-5" placeholder="kullanıcı adınız" style="background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.1); color: white;" />
                    </div>
                    <ValidationMessage For="@(() => model.UserName)" class="text-danger small mt-1" />
                </div>

                <div class="mb-3">
                    <label class="form-label text-white-50 small fw-bold text-uppercase opacity-75 ms-1 mb-2">E-Posta</label>
                    <div class="position-relative">
                        <i class="bi bi-envelope position-absolute top-50 start-0 translate-middle-y ms-3 text-white-50 opacity-50"></i>
                        <InputText @bind-Value="model.Email" type="email" class="form-control ps-5" placeholder="email@adres.com" style="background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.1); color: white;" />
                    </div>
                    <ValidationMessage For="@(() => model.Email)" class="text-danger small mt-1" />
                </div>

                <div class="mb-4">
                    <label class="form-label text-white-50 small fw-bold text-uppercase opacity-75 ms-1 mb-2">Şifre</label>
                    <div class="position-relative">
                        <i class="bi bi-key position-absolute top-50 start-0 translate-middle-y ms-3 text-white-50 opacity-50"></i>
                        <InputText @bind-Value="model.Password" type="password" class="form-control ps-5" placeholder="••••••••" style="background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.1); color: white;" />
                    </div>
                    <ValidationMessage For="@(() => model.Password)" class="text-danger small mt-1" />
                </div>

                <button type="submit" class="btn btn-success w-100 py-3 fw-bold mb-4" style="border-radius: 12px; background: linear-gradient(135deg, #22c55e, #16a34a); border: none; box-shadow: 0 4px 15px rgba(34, 197, 94, 0.3);">
                    Kaydı Tamamla <i class="bi bi-check2-circle ms-2"></i>
                </button>
            </EditForm>
            
            @if (!string.IsNullOrEmpty(msg))
            {
                <div class="alert alert-info border-0 bg-info bg-opacity-10 text-info small py-2 text-center" style="border-radius: 10px;">
                    <i class="bi bi-info-circle me-2"></i> @msg
                </div>
            }

            <div class="text-center mt-4 border-top border-white border-opacity-10 pt-4">
                <p class="text-white-50 small mb-0">Zaten üye misiniz?</p>
                <a href="/login" class="fw-bold text-primary mt-2 d-inline-block">Giriş Yap</a>
            </div>
        </div>
    </div>
</div>

@code {
    private UserRegisterDto model = new();
    private string msg = "";

    private async Task HandleRegister()
    {
        msg = "";
        try
        {
            var (success, error) = await AuthService.Register(model);
            if (success)
            {
                ToastService.Notify("Kayıt başarılı! Giriş sayfasına yönlendiriliyorsunuz...", ToastLevel.Success);
                await Task.Delay(1500);
                Nav.NavigateTo("/login");
            }
            else
            {
                // API'den gelen karmaşık JSON hatasını ayıkla (Örn: Validasyon hataları)
                try {
                    using var doc = System.Text.Json.JsonDocument.Parse(error ?? "{}");
                    if (doc.RootElement.TryGetProperty("errors", out var errors))
                    {
                        var firstError = errors.EnumerateObject().FirstOrDefault();
                        var firstMessage = firstError.Value.EnumerateArray().FirstOrDefault().GetString();
                        msg = firstMessage ?? "Kayıt başarısız.";
                    }
                    else if (doc.RootElement.TryGetProperty("message", out var message))
                    {
                        msg = message.GetString() ?? "Kayıt başarısız.";
                    }
                    else {
                        msg = error ?? "Kayıt başarısız.";
                    }
                } catch {
                    msg = error ?? "Kayıt başarısız.";
                }

                ToastService.Notify("Kayıt sırasında bir hata oluştu!", ToastLevel.Error);
            }
        }
        catch (Exception ex)
        {
            ToastService.Notify($"Hata: {ex.Message}", ToastLevel.Error);
        }
    }
}
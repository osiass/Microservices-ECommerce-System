@page "/register"
@using WebUI.Services
@using Common.DTOs
@inject AuthService AuthService
@inject NavigationManager Nav
@inject ToastService ToastService

<PageTitle>Kayıt Ol | E-Ticaret</PageTitle>

<div class="auth-page">
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-icon" style="background:#000;">
                <i class="bi bi-person-plus-fill"></i>
            </div>
            <h2 class="auth-title">Hesap Oluştur</h2>
            <p class="auth-sub">Saniyeler içinde katılın</p>

            <EditForm Model="model" OnValidSubmit="HandleRegister">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label class="auth-label">Kullanıcı Adı</label>
                    <div class="auth-input-wrap">
                        <i class="bi bi-person auth-input-icon"></i>
                        <InputText @bind-Value="model.UserName" class="auth-input" placeholder="kullanıcı adınız" />
                    </div>
                    <ValidationMessage For="@(() => model.UserName)" class="text-danger small mt-1 ms-3" />
                </div>

                <div class="mb-3">
                    <label class="auth-label">E-Posta</label>
                    <div class="auth-input-wrap">
                        <i class="bi bi-envelope auth-input-icon"></i>
                        <InputText @bind-Value="model.Email" type="email" class="auth-input" placeholder="email@adres.com" />
                    </div>
                    <ValidationMessage For="@(() => model.Email)" class="text-danger small mt-1 ms-3" />
                </div>

                <div class="mb-4">
                    <label class="auth-label">Şifre</label>
                    <div class="auth-input-wrap">
                        <i class="bi bi-lock auth-input-icon"></i>
                        <InputText @bind-Value="model.Password" type="password" class="auth-input" placeholder="••••••••" />
                    </div>
                    <ValidationMessage For="@(() => model.Password)" class="text-danger small mt-1 ms-3" />
                </div>

                <button type="submit" class="btn btn-primary w-100 py-3 fw-bold">
                    Kaydı Tamamla &nbsp;<i class="bi bi-check2-circle"></i>
                </button>
            </EditForm>

            @if (!string.IsNullOrEmpty(msg))
            {
                <div class="auth-error mt-3">
                    <i class="bi bi-info-circle me-2"></i>@msg
                </div>
            }

            <div class="auth-footer">
                <p class="text-muted small mb-2">Zaten üye misiniz?</p>
                <a href="/login" class="fw-bold text-decoration-none" style="color:#000;">Giriş Yap →</a>
            </div>
        </div>
    </div>
</div>

@code {
    private UserRegisterDto model = new();
    private string msg = "";

    private async Task HandleRegister()
    {
        msg = "";
        try
        {
            var (success, error) = await AuthService.Register(model);
            if (success)
            {
                ToastService.Notify("Kayıt başarılı! Giriş sayfasına yönlendiriliyorsunuz...", ToastLevel.Success);
                await Task.Delay(1500);
                Nav.NavigateTo("/login");
            }
            else
            {
                try
                {
                    using var doc = System.Text.Json.JsonDocument.Parse(error ?? "{}");
                    if (doc.RootElement.TryGetProperty("errors", out var errors))
                    {
                        var firstError = errors.EnumerateObject().FirstOrDefault();
                        var firstMessage = firstError.Value.EnumerateArray().FirstOrDefault().GetString();
                        msg = firstMessage ?? "Kayıt başarısız.";
                    }
                    else if (doc.RootElement.TryGetProperty("message", out var message))
                    {
                        msg = message.GetString() ?? "Kayıt başarısız.";
                    }
                    else
                    {
                        msg = error ?? "Kayıt başarısız.";
                    }
                }
                catch { msg = error ?? "Kayıt başarısız."; }
                ToastService.Notify("Kayıt sırasında bir hata oluştu!", ToastLevel.Error);
            }
        }
        catch (Exception ex)
        {
            ToastService.Notify($"Hata: {ex.Message}", ToastLevel.Error);
        }
    }
}

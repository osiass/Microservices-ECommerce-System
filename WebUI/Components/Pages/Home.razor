@page "/"
@using WebUI.Services
@using Common.DTOs
@using Blazored.LocalStorage
@inject BasketService BasketService
@inject CatalogService CatalogService
@inject ToastService ToastService
@inject ILocalStorageService LocalStore
@inject NavigationManager Nav

<PageTitle>E-Ticaret Vitrini - Keşfet</PageTitle>

<PageTitle>E-Ticaret | Geleceğin Teknolojisi</PageTitle>

<!-- Hero Section -->
<div class="hero-wrapper animate-fade-in">
    <div class="container h-100 d-flex align-items-center justify-content-center text-center">
        <div class="hero-content">
            <h1 class="hero-display mb-3">Teknolojide <span class="text-gradient">Yeni Nesil</span></h1>
            <p class="hero-lead mb-5">En gelişmiş donanımlar ve oyuncu aksesuarları, profesyoneller için burada.</p>
            
            <div class="hero-search-box mx-auto">
                <i class="bi bi-search ms-3 glass-icon"></i>
                <input type="text" class="flex-grow-1 border-0 bg-transparent text-white px-3 py-2" 
                       placeholder="Ne aramıştınız?" 
                       @bind="searchTerm" @bind:event="oninput" @onkeyup="HandleKeyUp" />
                @if (!string.IsNullOrEmpty(searchTerm))
                {
                    <button class="btn-clear me-2" @onclick="ClearSearch"><i class="bi bi-x"></i></button>
                }
                <button class="btn btn-primary px-4 py-2" @onclick="LoadProducts">Hadi Bakalım</button>
            </div>
        </div>
    </div>
</div>

<div class="container pb-5">
    <!-- Category Filter Chips -->
    <div class="d-flex flex-wrap justify-content-center gap-2 mb-5 animate-up">
        <button class="category-chip @(selectedCategory == null ? "active" : "")" 
                @onclick="() => FilterByCategory(null)">Hepsi</button>
        @foreach (var cat in categories)
        {
            <button class="category-chip @(selectedCategory == cat ? "active" : "")" 
                    @onclick="() => FilterByCategory(cat)">@cat</button>
        }
    </div>

    <!-- Product Grid -->
    <div class="row g-4 animate-up">
        @if (isLoading)
        {
            @for (int i = 0; i < 8; i++)
            {
                <div class="col-sm-6 col-lg-4 col-xl-3">
                    <div class="glass-card h-100 shimmer-wrapper" style="min-height: 400px; border-radius: 20px;"></div>
                </div>
            }
        }
        else if (products == null || !products.Any())
        {
            <div class="col-12 text-center py-5">
                <div class="empty-state">
                    <i class="bi bi-search-heart mb-4" style="font-size: 4rem; opacity: 0.3;"></i>
                    <h3 class="fw-bold">Aradığınızı Bulamadık</h3>
                    <p class="text-muted mb-4">Farklı anahtar kelimelerle şansınızı tekrar deneyin.</p>
                    <button class="btn btn-outline-primary px-5 py-2 rounded-pill" @onclick="ResetFilters">Tüm Vitrini Gör</button>
                </div>
            </div>
        }
        else
        {
            @foreach (var prod in products)
            {
                <div class="col-sm-6 col-lg-4 col-xl-3">
                    <div class="glass-card product-card h-100">
                        <!-- Image Area -->
                        <div class="product-img-box" @onclick='() => Nav.NavigateTo($"/product/{prod.Id}")'>
                            @if (!string.IsNullOrEmpty(prod.ImageUrl))
                            {
                                <img src="@CatalogService.GetFullImageUrl(prod.ImageUrl)" class="product-image" alt="@prod.Name" />
                            }
                            else
                            {
                                <div class="placeholder-icon"><i class="bi bi-box-seam-fill"></i></div>
                            }
                            <span class="product-category-badge">@prod.Category</span>
                            @if (prod.StockQuantity <= 0)
                            {
                                <div class="sold-out-overlay">
                                    <span class="badge bg-danger">Tükendi</span>
                                </div>
                            }
                        </div>

                        <!-- Info Area -->
                        <div class="product-info-box p-4">
                            <h5 class="product-title @(addedProductId == prod.Id.ToString() ? "text-success-glow" : "")" 
                                @onclick='() => Nav.NavigateTo($"/product/{prod.Id}")'>@prod.Name</h5>
                            <p class="product-desc">@prod.Description</p>
                            
                            <div class="product-footer mt-auto pt-3">
                                <div class="price-box">
                                    <small class="text-white-50 d-block">Başlayan fiyatlarla</small>
                                    <span class="price-val">@prod.Price.ToString("C2")</span>
                                </div>
                                <button class="btn-quick-add @(addedProductId == prod.Id.ToString() ? "btn-success-glow" : "")" 
                                        @onclick="() => AddToCart(prod)" 
                                        disabled="@busyProducts.Contains(prod.Id.ToString())">
                                    @if (busyProducts.Contains(prod.Id.ToString()))
                                    {
                                        <div class="spinner-border spinner-border-sm"></div>
                                    }
                                    else if (addedProductId == prod.Id.ToString())
                                    {
                                        <i class="bi bi-check2"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-cart-plus"></i>
                                    }
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>



@code {
    private List<ProductDto>? products;
    private string searchTerm = "";
    private string? selectedCategory;
    private bool isLoading = true;
    private HashSet<string> busyProducts = new();
    private string? addedProductId;

    private List<string> categories = new() { "Klavye", "Mouse", "Kasa", "Kulaklık", "Monitör" };

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        isLoading = true;
        StateHasChanged();
        try
        {
            products = await CatalogService.GetProducts(searchTerm, selectedCategory);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ürün yükleme hatası: {ex.Message}");
            ToastService.Notify("Ürünler yüklenirken bir sorun oluştu.", ToastLevel.Error);
            products = new();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task FilterByCategory(string? category)
    {
        selectedCategory = category;
        await LoadProducts();
    }

    private async Task ClearSearch()
    {
        searchTerm = "";
        await LoadProducts();
    }

    private async Task ResetFilters()
    {
        searchTerm = "";
        selectedCategory = null;
        await LoadProducts();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await LoadProducts();
        }
    }

    private async Task AddToCart(ProductDto product)
    {
        var productKey = product.Id.ToString();
        if (busyProducts.Contains(productKey)) return; 

        var authToken = await LocalStore.GetItemAsync<string>("authToken");
        var userName = await LocalStore.GetItemAsync<string>("userName");

        if (string.IsNullOrWhiteSpace(authToken) || string.IsNullOrWhiteSpace(userName) || authToken == "null")
        {
            // Misafir kullanıcı için bir ID oluştur veya mevcut olanı al
            userName = await LocalStore.GetItemAsync<string>("guestId");
            if (string.IsNullOrEmpty(userName))
            {
                userName = "guest-" + Guid.NewGuid().ToString().Substring(0, 8);
                await LocalStore.SetItemAsync("guestId", userName);
            }
            authToken = string.Empty;
        }

        busyProducts.Add(productKey);
        StateHasChanged();

        try
        {
            var result = await BasketService.AddItem(authToken, userName, product);
            if (result.Success)
            {
                ToastService.Notify($"{product.Name} sepete eklendi!", ToastLevel.Success);
                addedProductId = productKey;
                StateHasChanged();
                await Task.Delay(1000);
                addedProductId = null;
            }
            else
            {
                addedProductId = null;
                if (result.Message.Contains("401"))
                {
                    await LocalStore.RemoveItemAsync("authToken");
                    await LocalStore.RemoveItemAsync("userName");
                    ToastService.Notify("Oturumunuzun süresi dolmuş. Lütfen tekrar giriş yapın.", ToastLevel.Warning);
                    Nav.NavigateTo("/login", forceLoad: true);
                }
                else
                {
                    ToastService.Notify($"Hata: {result.Message}", ToastLevel.Error);
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Sepete ekleme hatası: {ex.Message}");
            ToastService.Notify("Bağlantı sorunu nedeniyle ürün eklenemedi.", ToastLevel.Error);
        }
        finally
        {
            busyProducts.Remove(productKey);
            StateHasChanged();
        }
    }
}
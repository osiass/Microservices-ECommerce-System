@page "/"
@using WebUI.Services
@using Common.DTOs
@using Blazored.LocalStorage
@inject BasketService BasketService
@inject CatalogService CatalogService
@inject ToastService ToastService
@inject ILocalStorageService LocalStore
@inject NavigationManager Nav

<PageTitle>E-Ticaret | Keşfet & Alışveriş</PageTitle>

<!-- ── Hero Section ── -->
<div class="hero-wrapper animate-fade-in">
    <div class="container">
        <div class="row align-items-center">

            <!-- Left: Text -->
            <div class="col-lg-6 hero-left">
                <h1 class="hero-display">TEKNOLOJİDE<br />FARKINI<br />ORTAYA KOY</h1>
                <p class="hero-lead">
                    Klavye, mouse, kulaklık ve daha fazlası — ihtiyacın olan her şey tek adreste, en iyi fiyatlarla.
                </p>
                <a href="/products" class="btn btn-primary btn-lg rounded-pill px-5 py-3">
                    Ürünleri Keşfet
                </a>

                <!-- Stats -->
                <div class="hero-stats">
                    <div class="hero-stat">
                        <span class="stat-num">200+</span>
                        <span class="stat-lbl">Ürün Çeşidi</span>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="hero-stat">
                        <span class="stat-num">1,000+</span>
                        <span class="stat-lbl">Mutlu Müşteri</span>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="hero-stat">
                        <span class="stat-num">5</span>
                        <span class="stat-lbl">Kategori</span>
                    </div>
                </div>
            </div>

            <!-- Right: Visual -->
            <div class="col-lg-6 d-none d-lg-flex justify-content-center">
                <div class="hero-visual">
                    <div class="hero-circle"></div>
                    <i class="bi bi-laptop hero-main-icon"></i>
                    <div class="hero-badge hero-badge-1">
                        <i class="bi bi-star-fill text-warning"></i>&nbsp; En Çok Satan
                    </div>
                    <div class="hero-badge hero-badge-2">
                        <i class="bi bi-shield-check"></i>&nbsp; Güvenli Ödeme
                    </div>
                    <div class="hero-badge hero-badge-3">
                        🔥 Yeni Sezon
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- ── Brand Strip ── -->
<div class="brand-strip">
    <div class="brand-track">
        <span>LOGITECH</span><span>RAZER</span><span>CORSAIR</span>
        <span>HYPERX</span><span>SAMSUNG</span><span>ASUS</span>
        <span>MSI</span><span>KINGSTON</span>
        <!-- duplicate for seamless loop -->
        <span>LOGITECH</span><span>RAZER</span><span>CORSAIR</span>
        <span>HYPERX</span><span>SAMSUNG</span><span>ASUS</span>
        <span>MSI</span><span>KINGSTON</span>
    </div>
</div>

<!-- ── Products Section ── -->
<div class="container pb-5" id="products-section">
    <div class="section-header">
        <h2 class="section-title">ÖNE ÇIKAN<br /><span>ÜRÜNLER</span></h2>
        <a href="products" class="btn btn-outline-dark px-4">Tümünü Gör →</a>
    </div>

    <!-- Category Chips -->
    <div class="d-flex flex-wrap justify-content-center gap-2 mb-5">
        <button class="category-chip @(selectedCategory == null ? "active" : "")"
                @onclick="() => FilterByCategory(null)">Hepsi</button>
        @foreach (var cat in categories)
        {
            <button class="category-chip @(selectedCategory == cat ? "active" : "")"
                    @onclick="() => FilterByCategory(cat)">@cat</button>
        }
    </div>

    <!-- Product Grid -->
    <div class="row g-4">
        @if (isLoading)
        {
            @for (int i = 0; i < 8; i++)
            {
                <div class="col-sm-6 col-lg-4 col-xl-3">
                    <div class="shimmer-wrapper" style="height:380px; border-radius:20px;"></div>
                </div>
            }
        }
        else if (products == null || !products.Any())
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-search mb-3 d-block" style="font-size:3rem; opacity:0.2;"></i>
                <h5 class="fw-bold">Ürün bulunamadı</h5>
                <p class="text-muted">Farklı bir kategori deneyin.</p>
                <button class="btn btn-outline-dark px-5 mt-2 rounded-pill" @onclick="ResetFilters">Tümünü Göster</button>
            </div>
        }
        else
        {
            @foreach (var prod in products)
            {
                <div class="col-sm-6 col-lg-4 col-xl-3">
                    <div class="glass-card product-card h-100">
                        <div class="product-img-box" @onclick='() => Nav.NavigateTo($"/product/{prod.Id}")'>
                            @if (!string.IsNullOrEmpty(prod.ImageUrl))
                            {
                                <img src="@CatalogService.GetFullImageUrl(prod.ImageUrl)" class="product-image" alt="@prod.Name" />
                            }
                            else
                            {
                                <i class="bi bi-box-seam-fill placeholder-icon"></i>
                            }
                            <span class="product-category-badge">@prod.Category</span>
                            @if (prod.StockQuantity <= 0)
                            {
                                <div class="sold-out-overlay"><span>Tükendi</span></div>
                            }
                        </div>

                        <div class="product-info-box p-3">
                            <div class="star-rating mb-1">
                                @for (int s = 1; s <= 5; s++)
                                {
                                    <i class="bi @(s <= (int)prod.Rating ? "bi-star-fill" : "bi-star")"></i>
                                }
                                @if (prod.Rating > 0)
                                {
                                    <span class="text-muted ms-1" style="font-size:0.8rem;">@prod.Rating.ToString("0.0")/5</span>
                                }
                            </div>
                            <h5 class="product-title" @onclick='() => Nav.NavigateTo($"/product/{prod.Id}")'>@prod.Name</h5>
                            <p class="product-desc">@prod.Description</p>

                            <div class="product-footer mt-auto">
                                <span class="price-val">@prod.Price.ToString("C2")</span>
                                <button class="btn-quick-add @(addedProductId == prod.Id.ToString() ? "added" : "")"
                                        @onclick="() => AddToCart(prod)"
                                        disabled="@busyProducts.Contains(prod.Id.ToString())">
                                    @if (busyProducts.Contains(prod.Id.ToString()))
                                    {
                                        <div class="spinner-border spinner-border-sm"></div>
                                    }
                                    else if (addedProductId == prod.Id.ToString())
                                    {
                                        <i class="bi bi-check2"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-cart-plus"></i>
                                    }
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private List<ProductDto>? products;
    private string searchTerm = "";
    private string? selectedCategory;
    private bool isLoading = true;
    private HashSet<string> busyProducts = new();
    private string? addedProductId;

    private List<string> categories = new() { "Klavye", "Mouse", "Kasa", "Kulaklık", "Monitör" };

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        isLoading = true;
        StateHasChanged();
        try
        {
            products = await CatalogService.GetProducts(searchTerm, selectedCategory);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ürün yükleme hatası: {ex.Message}");
            ToastService.Notify("Ürünler yüklenirken bir sorun oluştu.", ToastLevel.Error);
            products = new();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task FilterByCategory(string? category)
    {
        selectedCategory = category;
        await LoadProducts();
    }

    private void ScrollToProducts() => Nav.NavigateTo("/products");

    private async Task ResetFilters()
    {
        searchTerm = "";
        selectedCategory = null;
        await LoadProducts();
    }

    private async Task AddToCart(ProductDto product)
    {
        var productKey = product.Id.ToString();
        if (busyProducts.Contains(productKey)) return;

        var authToken = await LocalStore.GetItemAsync<string>("authToken");
        var userName = await LocalStore.GetItemAsync<string>("userName");

        if (string.IsNullOrWhiteSpace(authToken) || string.IsNullOrWhiteSpace(userName) || authToken == "null")
        {
            userName = await LocalStore.GetItemAsync<string>("guestId");
            if (string.IsNullOrEmpty(userName))
            {
                userName = "guest-" + Guid.NewGuid().ToString().Substring(0, 8);
                await LocalStore.SetItemAsync("guestId", userName);
            }
            authToken = string.Empty;
        }

        busyProducts.Add(productKey);
        StateHasChanged();

        try
        {
            var result = await BasketService.AddItem(authToken, userName, product);
            if (result.Success)
            {
                ToastService.Notify($"{product.Name} sepete eklendi!", ToastLevel.Success);
                addedProductId = productKey;
                StateHasChanged();
                await Task.Delay(1000);
                addedProductId = null;
            }
            else
            {
                addedProductId = null;
                if (result.Message.Contains("401"))
                {
                    await LocalStore.RemoveItemAsync("authToken");
                    await LocalStore.RemoveItemAsync("userName");
                    ToastService.Notify("Oturumunuzun süresi dolmuş. Lütfen tekrar giriş yapın.", ToastLevel.Warning);
                    Nav.NavigateTo("/login", forceLoad: true);
                }
                else
                {
                    ToastService.Notify($"Hata: {result.Message}", ToastLevel.Error);
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Sepete ekleme hatası: {ex.Message}");
            ToastService.Notify("Bağlantı sorunu nedeniyle ürün eklenemedi.", ToastLevel.Error);
        }
        finally
        {
            busyProducts.Remove(productKey);
            StateHasChanged();
        }
    }
}

@page "/checkout"
@using WebUI.Services
@using Common.DTOs
@using Blazored.LocalStorage
@inject BasketService BasketService
@inject OrderService OrderService
@inject ILocalStorageService LocalStore
@inject NavigationManager Nav

<div class="container pt-5 pb-5 animate-fade-in">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="glass-card p-4 p-md-5 animate-up">
                <div class="text-center mb-5">
                    <div class="checkout-header-icon mb-3">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h2 class="fw-bold mb-2">Güvenli <span class="text-gradient">Ödeme</span></h2>
                    <p class="text-muted small">Siparişinizi tamamlamadan önce son bir adım kaldı.</p>
                </div>

                <!-- Adres Bölümü -->
                <div class="mb-4">
                    <label class="form-label fw-bold small text-uppercase opacity-50 mb-2">Teslimat Adresi</label>
                    <div class="position-relative">
                        <i class="bi bi-geo-alt position-absolute top-50 start-0 translate-middle-y ms-3 text-primary-glow"></i>
                        <input @bind="address" class="form-control glass-input ps-5" placeholder="Sokak, No, Kat, Daire..." />
                    </div>
                </div>

                <div class="border-top border-white border-opacity-10 my-5 pt-1"></div>

                <!-- Kart Bilgileri -->
                <div class="payment-section">
                    <label class="form-label fw-bold small text-uppercase opacity-50 mb-3">Kart Bilgileri</label>
                    
                    <div class="mb-3">
                        <label class="small text-muted mb-1">Kart Üzerindeki İsim</label>
                        <input @bind="cardHolderName" class="form-control glass-input" placeholder="Ad Soyad" />
                    </div>

                    <div class="mb-3">
                        <label class="small text-muted mb-1">Kart Numarası</label>
                        <div class="position-relative">
                            <input @bind="cardNumber" class="form-control glass-input" placeholder="0000 0000 0000 0000" maxlength="16" />
                            <i class="bi bi-credit-card position-absolute top-50 end-0 translate-middle-y me-3 opacity-50"></i>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-4">
                            <label class="small text-muted mb-1">Ay</label>
                            <input @bind="expMonth" class="form-control glass-input text-center" placeholder="AA" maxlength="2" />
                        </div>
                        <div class="col-4">
                            <label class="small text-muted mb-1">Yıl</label>
                            <input @bind="expYear" class="form-control glass-input text-center" placeholder="YY" maxlength="2" />
                        </div>
                        <div class="col-4">
                            <label class="small text-muted mb-1">CVV</label>
                            <input @bind="cvv" type="password" class="form-control glass-input text-center" placeholder="***" maxlength="3" />
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger-glass mb-4">
                        <i class="bi bi-exclamation-octagon-fill me-2"></i>@errorMessage
                    </div>
                }

                <button class="btn btn-primary btn-lg w-100 py-3 fw-bold rounded-4 shadow-glow mt-4" 
                        @onclick="ConfirmOrder" disabled="@isProcessing">
                    @if (isProcessing)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span> <span>İşlem Sürüyor...</span>
                    }
                    else
                    {
                        <span>Ödemeyi Onayla ve Sipariş Ver</span> <i class="bi bi-check2-circle ms-2"></i>
                    }
                </button>
                
                <div class="text-center mt-5">
                    <div class="d-flex justify-content-center gap-3 opacity-25 grayscale mb-3">
                        <i class="bi bi-lock-fill"></i>
                        <span>SSL SECURED</span>
                    </div>
                    <p class="text-muted extra-small">Kredi kartı bilgileriniz sunucularımızda saklanmaz, doğrudan banka altyapısına iletilir.</p>
                </div>
            </div>
        </div>
    </div>
</div>



@code {
    private string address = "";
    private string cardNumber = "";
    private string cardHolderName = "";
    private string expMonth = "";
    private string expYear = "";
    private int cvv;
    
    private string errorMessage = "";
    private bool isProcessing = false;

    protected override async Task OnInitializedAsync()
    {
        var token = await LocalStore.GetItemAsync<string>("authToken");
        var user = await LocalStore.GetItemAsync<string>("userName");

        //Token veya kullanıcı adı yoksa sayfaya eriştirmeden login atı
        if (string.IsNullOrEmpty(token) || token == "null" || string.IsNullOrEmpty(user))
        {
            Nav.NavigateTo("/login");
        }
    }
    
    private async Task ConfirmOrder()
    {
        errorMessage = "";
        
        if (string.IsNullOrWhiteSpace(address) || string.IsNullOrWhiteSpace(cardNumber) || string.IsNullOrWhiteSpace(cardHolderName))
        {
            errorMessage = "Lütfen tüm alanları eksiksiz doldurun.";
            return;
        }

        isProcessing = true;
        
        try 
        {
            var token = await LocalStore.GetItemAsync<string>("authToken");
            var user = await LocalStore.GetItemAsync<string>("userName");

            if (!string.IsNullOrEmpty(token) && !string.IsNullOrEmpty(user))
            {
                // Sepeti APIden güncel olarak çek
                var basket = await BasketService.GetBasket(token, user);
                
                if (basket == null || basket.Items == null || !basket.Items.Any())
                {
                    errorMessage = "Sepetiniz boş olduğu için sipariş verilemiyor.";
                    isProcessing = false;
                    return;
                }

                var checkoutDto = new BasketCheckoutDto
                {
                    UserName = user,
                    AddressLine = address,
                    CardNumber = cardNumber,
                    CardHolderName = cardHolderName,
                    ExpirationMonth = int.TryParse(expMonth, out var m) ? m : 0,
                    ExpirationYear = int.TryParse(expYear, out var y) ? y : 0,
                    CVV = cvv,
                    Items = basket.Items
                };

                // OrderService.Checkout metodundan dönen Tuple değerini kontrol 
                var result = await OrderService.Checkout(token, checkoutDto);

                if (result.Success)
                {
                    // Ödeme başarılı sepeti temizle
                    var deleteRes = await BasketService.DeleteBasket(token, user);
                    if (!deleteRes.Success)
                    {
                        Console.WriteLine($"[Checkout.razor] Sepet API'den silinemedi! Hata: {deleteRes.Message}");
                    }
                    Nav.NavigateTo("/order-success");
                }
                else
                {
                    errorMessage = $"Sipariş tamamlanamadı: {result.Message}";
                    var diag = await OrderService.GetAuthStatus(token);
                    errorMessage += $" | Teşhis: {diag}";
                }
            }
            else
            {
                Nav.NavigateTo("/login");
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Beklenmedik bir hata oluştu: " + ex.Message;
        }
        finally
        {
            isProcessing = false;
        }
    }
}
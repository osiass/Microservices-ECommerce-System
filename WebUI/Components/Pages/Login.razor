@page "/login"
@using WebUI.Services
@using Blazored.LocalStorage
@inject AuthService AuthService
@inject NavigationManager Nav
@inject ILocalStorageService LocalStorage
@inject ToastService ToastService
@inject WebUI.Providers.CustomAuthStateProvider AuthProvider

<PageTitle>Giriş Yap | E-Ticaret</PageTitle>

<div class="auth-page">
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-icon">
                <i class="bi bi-bag-check-fill"></i>
            </div>
            <h2 class="auth-title">Giriş Yap</h2>
            <p class="auth-sub">Hesabınıza güvenle erişin</p>

            <div class="mb-4">
                <label class="auth-label">Kullanıcı Adı</label>
                <div class="auth-input-wrap">
                    <i class="bi bi-person auth-input-icon"></i>
                    <input @bind="username" class="auth-input" placeholder="kullanıcı adınız" />
                </div>
            </div>

            <div class="mb-4">
                <label class="auth-label">Şifre</label>
                <div class="auth-input-wrap">
                    <i class="bi bi-lock auth-input-icon"></i>
                    <input @bind="password" type="password" class="auth-input" placeholder="••••••••" />
                </div>
            </div>

            <button @onclick="HandleLogin" class="btn btn-primary w-100 py-3 fw-bold">
                Giriş Yap &nbsp;<i class="bi bi-arrow-right"></i>
            </button>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="auth-error mt-3">
                    <i class="bi bi-exclamation-circle me-2"></i>@errorMessage
                </div>
            }

            <div class="auth-footer">
                <p class="text-muted small mb-2">Henüz hesabınız yok mu?</p>
                <a href="/register" class="fw-bold text-decoration-none" style="color:#000;">Yeni Hesap Oluştur →</a>
            </div>
        </div>
    </div>
</div>

@code {
    private string username = "";
    private string password = "";
    private string errorMessage = "";

    private async Task HandleLogin()
    {
        errorMessage = "";
        try
        {
            var result = await AuthService.Login(username, password);
            if (result.Token != null)
            {
                await LocalStorage.SetItemAsync("authToken", result.Token);
                await LocalStorage.SetItemAsync("userName", username);
                await LocalStorage.SetItemAsync("userRole", result.Role);
                AuthProvider.NotifyUserLogin(username, result.Role);
                ToastService.Notify("Giriş başarılı! Hoş geldiniz.", ToastLevel.Success);
                Nav.NavigateTo("/");
            }
            else
            {
                errorMessage = "Kullanıcı adı veya şifre hatalı!";
                ToastService.Notify("Giriş başarısız!", ToastLevel.Error);
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Bağlantı hatası: " + ex.Message;
            ToastService.Notify("Bağlantı hatası oluştu!", ToastLevel.Error);
        }
    }
}

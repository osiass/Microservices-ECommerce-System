@page "/basket"
@using WebUI.Services
@using Blazored.LocalStorage
@using Common.DTOs
@inject BasketService BasketService
@inject OrderService OrderService
@inject ToastService ToastService
@inject ILocalStorageService LocalStore
@inject NavigationManager Nav
@inject CatalogService CatalogService
@inject DiscountService DiscountService

<div class="container pt-4 pb-5 animate-fade-in">
    <div class="d-flex align-items-center mb-5">
        <h2 class="display-6 fw-bold mb-0">Alışveriş <span class="text-gradient">Sepetim</span></h2>
        <div class="ms-3 h-100 border-start border-white border-opacity-10 ps-3">
            <span class="text-white-50">@(cart?.Items?.Count ?? 0) Ürün</span>
        </div>
    </div>

    <div class="row g-4">
        <!-- Sepet Listesi -->
        <div class="col-lg-8">
            @if (cart == null)
            {
                <div class="glass-card p-5 text-center">
                    <div class="spinner-border text-primary shadow-glow mb-3"></div>
                    <p class="text-muted">Sepetiniz hazırlanıyor...</p>
                </div>
            }
            else if (!cart.Items.Any())
            {
                <div class="glass-card p-5 text-center animate-up">
                    <div class="empty-basket-icon mb-4">
                        <i class="bi bi-cart-x"></i>
                    </div>
                    <h3 class="fw-bold mb-3 text-white">Sepetiniz Boş</h3>
                    <p class="text-white opacity-75 mb-4 px-lg-5">Görünüşe göre henüz bir ürün eklememişsiniz. Harika fırsatları keşfetmeye ne dersiniz?</p>
                    <a href="/" class="btn btn-primary px-5 py-3 rounded-pill fw-bold">Alışverişe Başla</a>
                </div>
            }
            else
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var item in cart.Items.OrderBy(x => x.ProductName))
                    {
                        <div class="glass-card p-3 p-md-4 basket-item-premium transition-smooth animate-up">
                            <div class="row align-items-center g-3">
                                <div class="col-auto">
                                    <div class="basket-img-wrapper" @onclick='() => Nav.NavigateTo($"/product/{item.ProductId}")'>
                                        <img src="@CatalogService.GetFullImageUrl(item.ImageUrl)" class="rounded-4" alt="@item.ProductName" />
                                    </div>
                                </div>
                                <div class="col">
                                    <h6 class="fw-bold mb-1 fs-5 text-truncate" style="max-width: 250px;">@item.ProductName</h6>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="text-primary-glow fw-bold">@item.Price.ToString("C2")</span>
                                        @if(item.OriginalPrice > item.Price)
                                        {
                                            <small class="text-muted text-decoration-line-through">@item.OriginalPrice.ToString("C2")</small>
                                            <span class="badge badge-discount">-%@((int)((1 - item.Price / item.OriginalPrice) * 100))</span>
                                        }
                                        @{
                                            var product = products.FirstOrDefault(p => p.Id.ToString() == item.ProductId);
                                            if (product != null && item.Quantity > product.StockQuantity)
                                            {
                                                <small class="text-danger-glow ms-2 fw-bold animate-pulse">
                                                    <i class="bi bi-exclamation-circle-fill me-1"></i> Stok Yetersiz! (Mevcut: @product.StockQuantity)
                                                </small>
                                            }
                                        }
                                    </div>
                                </div>
                                <div class="col-md-auto col-12 d-flex justify-content-between align-items-center mt-3 mt-md-0">
                                    <div class="quantity-controls-premium me-lg-4">
                                        <button class="qty-btn" @onclick="() => UpdateQuantity(item, -1)">-</button>
                                        <span class="qty-val">@item.Quantity</span>
                                        <button class="qty-btn" @onclick="() => UpdateQuantity(item, 1)">+</button>
                                    </div>
                                    <button class="btn btn-link text-danger p-2 opacity-75 hover-opacity-100" @onclick="() => RemoveItem(item)">
                                        <i class="bi bi-trash3-fill fs-5"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Özet Paneli -->
        <div class="col-lg-4">
            <div class="glass-card p-4 sticky-summary animate-up" style="top: 100px;">
                <h4 class="fw-bold mb-4">Sipariş Özeti</h4>
                
                <div class="summary-details mb-4 d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between text-muted small">
                        <span>Ara Toplam</span>
                        <span>@((cart?.Items.Sum(x => (x.OriginalPrice > 0 ? x.OriginalPrice : x.Price) * x.Quantity) ?? 0).ToString("C2"))</span>
                    </div>
                    @if(cart != null && cart.Items.Any(x => x.OriginalPrice > x.Price))
                    {
                        <div class="d-flex justify-content-between text-success-glow small">
                            <span>Toplamsal İndirim</span>
                            <span>-@((cart.Items.Sum(x => (x.OriginalPrice - x.Price) * x.Quantity)).ToString("C2"))</span>
                        </div>
                    }
                    <div class="d-flex justify-content-between text-muted small">
                        <span>Lojistik / Kargo</span>
                        <span class="text-white">Standart (Ücretsiz)</span>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-end mb-4 pt-3 border-top border-white border-opacity-10">
                    <span class="fw-bold text-muted mb-1">Genel Toplam</span>
                    <span class="h2 fw-black mb-0 text-gradient">@(((cart?.Items.Sum(x => x.Price * x.Quantity) ?? 0) - (cart?.Discount ?? 0)).ToString("C2"))</span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold small text-uppercase mb-2">İndirim Kuponu</label>
                    <div class="input-group">
                        <input @bind="couponCode" class="form-control glass-input" placeholder="KUPON10" style="border-top-right-radius: 0; border-bottom-right-radius: 0;" />
                        <button class="btn btn-outline-primary px-3" @onclick="ApplyCoupon" disabled="@isApplyingCoupon" style="border-top-left-radius: 0; border-bottom-left-radius: 0;">
                            @if(isApplyingCoupon) { <span class="spinner-border spinner-border-sm"></span> }
                            else { <span>Uygula</span> }
                        </button>
                    </div>
                    @if(!string.IsNullOrEmpty(cart?.CouponCode))
                    {
                        <div class="d-flex align-items-center mt-2 text-success-glow small">
                            <i class="bi bi-patch-check-fill me-2"></i>
                            <span><b>@cart.CouponCode</b> uygulandı! (-@cart.Discount.ToString("C2"))</span>
                            <button class="btn btn-link btn-sm text-danger p-0 ms-auto text-decoration-none" @onclick="RemoveCoupon">Kaldır</button>
                        </div>
                    }
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold small text-uppercase mb-2">Teslimat Adresi</label>
                    <textarea @bind="address" class="form-control glass-input" rows="3" placeholder="Sokağınız, apartman bilgileriniz..."></textarea>
                </div>

                @if (HasStockIssue())
                {
                    <div class="alert alert-warning bg-warning bg-opacity-10 text-warning border border-warning border-opacity-20 mb-4 rounded-4 small">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> Bazı ürünler stokta yetersiz. Lütfen miktarları güncelleyin.
                    </div>
                }

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger-glass mb-4">
                        <i class="bi bi-exclamation-octagon-fill me-2"></i>@errorMessage
                    </div>
                }

                <div class="d-grid gap-2">
                    <button class="btn btn-primary btn-lg py-3 fw-bold rounded-4 shadow-glow" 
                            @onclick="ConfirmCheckout" 
                            disabled="@(isCheckingOut || cart == null || !cart.Items.Any() || HasStockIssue())">
                        @if (isCheckingOut)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span> <span>Hazırlanıyor...</span>
                        }
                        else
                        {
                            <span>Ödeme Adımına Geç</span> <i class="bi bi-shield-lock-fill ms-2"></i>
                        }
                    </button>

                    <button class="btn btn-outline-danger btn-sm border-0 mt-2 opacity-75 hover-opacity-100" 
                            @onclick="ManualResetBasket" 
                            disabled="@isCheckingOut || @(cart == null || !cart.Items.Any())">
                        <i class="bi bi-trash2 me-2"></i>Sepeti Boşalt
                    </button>
                </div>

                <div class="text-center mt-5 d-flex justify-content-center gap-4 opacity-50 grayscale hover-opacity-100">
                    <i class="bi bi-credit-card-2-front fs-3"></i>
                    <i class="bi bi-paypal fs-3"></i>
                    <i class="bi bi-apple fs-3"></i>
                    <i class="bi bi-google fs-3"></i>
                </div>
            </div>
        </div>
    </div>
</div>



@code {
    private ShoppingCartDto cart = new();
    private string address = "";
    private string couponCode = "";
    private bool isApplyingCoupon = false;

    private List<ProductDto> products = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadBasket();
    }

    private async Task LoadBasket()
    {
        var token = await LocalStore.GetItemAsync<string>("authToken");
        var user = await LocalStore.GetItemAsync<string>("userName");

        if (string.IsNullOrEmpty(user))
        {
            user = await LocalStore.GetItemAsync<string>("guestId");
        }

        if (!string.IsNullOrEmpty(user))
        {
            cart = await BasketService.GetBasket(token ?? string.Empty, user);
            if (!string.IsNullOrEmpty(cart?.CouponCode))
            {
                couponCode = cart.CouponCode;
            }

            if (cart != null && cart.Items.Any())
            {
                products = await CatalogService.GetProducts();
            }
        }
    }

    private bool HasStockIssue()
    {
        if (cart == null || products == null) return false;
        foreach (var item in cart.Items)
        {
            var product = products.FirstOrDefault(p => p.Id.ToString() == item.ProductId);
            if (product != null && item.Quantity > product.StockQuantity)
            {
                return true;
            }
        }
        return false;
    }

    private async Task ApplyCoupon()
    {
        if (string.IsNullOrWhiteSpace(couponCode)) return;

        isApplyingCoupon = true;
        try 
        {
            var coupon = await DiscountService.GetDiscount(couponCode);
            if (coupon != null && coupon.IsActive)
            {
                cart.CouponCode = coupon.Code;
                cart.Discount = coupon.Amount;
                ToastService.Notify($"'{coupon.Code}' kuponu uygulandı!", ToastLevel.Success);
                
                var token = await LocalStore.GetItemAsync<string>("authToken");
                await BasketService.UpdateBasket(token ?? "", cart);
                StateHasChanged();
            }
            else
            {
                ToastService.Notify("Geçersiz veya süresi dolmuş kupon kodu!", ToastLevel.Error);
            }
        }
        catch (Exception ex)
        {
            ToastService.Notify("Kupon uygulanırken hata oluştu: " + ex.Message, ToastLevel.Error);
        }
        finally
        {
            isApplyingCoupon = false;
        }
    }

    private async Task RemoveCoupon()
    {
        if (cart == null) return;
        
        cart.CouponCode = null;
        cart.Discount = 0;
        couponCode = "";
        
        var token = await LocalStore.GetItemAsync<string>("authToken");
        await BasketService.UpdateBasket(token ?? "", cart);
        
        ToastService.Notify("Kupon kaldırıldı.", ToastLevel.Info);
        StateHasChanged();
    }

    private async Task UpdateQuantity(BasketItemDto item, int change)
    {
        var newQuantity = item.Quantity + change;

        if (newQuantity < 1)
        {
            await RemoveItem(item);
            return;
        }

        item.Quantity = newQuantity;
        
        var token = await LocalStore.GetItemAsync<string>("authToken");
        var user = await LocalStore.GetItemAsync<string>("userName") ?? await LocalStore.GetItemAsync<string>("guestId");

        if (cart != null && !string.IsNullOrEmpty(user))
        {
            await BasketService.UpdateBasket(token ?? string.Empty, cart);
            ToastService.Notify($"{item.ProductName} miktarı güncellendi.", ToastLevel.Success);
        }
    }

    private async Task RemoveItem(BasketItemDto item)
    {
        if(cart == null) return;

        cart.Items.Remove(item);
        
        var token = await LocalStore.GetItemAsync<string>("authToken");
        var user = await LocalStore.GetItemAsync<string>("userName") ?? await LocalStore.GetItemAsync<string>("guestId");

        if(!string.IsNullOrEmpty(user))
        {
            await BasketService.UpdateBasket(token ?? string.Empty, cart);
            ToastService.Notify($"{item.ProductName} sepetten çıkarıldı.", ToastLevel.Info);
        }
    }

    private string errorMessage = "";
    private bool isCheckingOut = false;

    private async Task ConfirmCheckout()
    {
        var token = await LocalStore.GetItemAsync<string>("authToken");
        var user = await LocalStore.GetItemAsync<string>("userName");

        // GUEST ENGELLEME
        if (string.IsNullOrEmpty(token) || token == "null" || string.IsNullOrEmpty(user))
        {
            ToastService.Notify("Sipariş vermek için lütfen önce giriş yapınız.", ToastLevel.Warning);
            Nav.NavigateTo("/login");
            return;
        }

        if (cart == null || cart.Items == null || !cart.Items.Any())
        {
            ToastService.Notify("Sepetiniz boş!", ToastLevel.Error);
            return;
        }

        Nav.NavigateTo($"/checkout?address={Uri.EscapeDataString(address)}");
    }

    private async Task ManualResetBasket()
    {
        var token = await LocalStore.GetItemAsync<string>("authToken");
        var user = await LocalStore.GetItemAsync<string>("userName") ?? await LocalStore.GetItemAsync<string>("guestId");
        
        if (string.IsNullOrEmpty(user))
        {
            ToastService.Notify("Kullanıcı bulunamadı.", ToastLevel.Error);
            return;
        }

        var res = await BasketService.DeleteBasket(token ?? "", user);
        if (res.Success)
        {
            cart = new ShoppingCartDto { UserName = user, Items = new List<BasketItemDto>() };
            ToastService.Notify("Sepet başarıyla temizlendi.", ToastLevel.Success);
            StateHasChanged();
        }
        else
        {
            ToastService.Notify($"Hata (Manual): {res.Message}", ToastLevel.Error);
        }
    }
}
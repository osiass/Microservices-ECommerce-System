@page "/my-orders"
@using WebUI.Services
@using Common.DTOs
@inject OrderService OrderService
@inject CatalogService CatalogService
@inject Blazored.LocalStorage.ILocalStorageService LocalStore
@inject NavigationManager Nav
@inject ToastService ToastService

<div class="container mt-5 pt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">Sipariş Geçmişim</h2>
        <button class="btn btn-outline-secondary btn-sm" @onclick='() => Nav.NavigateTo("/")'>
            <i class="bi bi-arrow-left"></i> Alışverişe Dön
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
            <p class="mt-3 text-muted">Siparişleriniz yükleniyor...</p>
        </div>
    }
    else if (orders == null || !orders.Any())
    {
        <div class="admin-card text-center py-5 border-0">
            <div class="card-body">
                <i class="bi bi-bag-x text-muted mb-3" style="font-size: 4rem; opacity: 0.2;"></i>
                <h4 class="fw-bold">Henüz hiç siparişiniz yok.</h4>
                <p class="text-muted mb-4 opacity-75">En sevdiğiniz ürünleri hemen keşfetmeye başlayın!</p>
                <button class="btn btn-primary px-5 py-2 mt-2" @onclick='() => Nav.NavigateTo("/")' style="">
                    Alışverişe Başla
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4 mb-5">
            @foreach (var order in orders)
            {
                <div class="col-12">
                    <div class="admin-card order-card border-0 overflow-hidden">
                        <div class="card-body p-4">
                            <div class="row align-items-center">
                                <div class="col-md-3">
                                    <p class="text-muted small mb-1 text-uppercase fw-bold opacity-50">Sipariş Tarihi</p>
                                    <h6 class="mb-0 fw-semibold">@order.CreatedDate.ToString("dd MMMM yyyy HH:mm")</h6>
                                </div>
                                <div class="col-md-2">
                                    <p class="text-muted small mb-1 text-uppercase fw-bold opacity-50">Sipariş No</p>
                                    <h6 class="mb-0 text-primary fw-bold">#ORD-@order.Id.ToString("D5")</h6>
                                </div>
                                <div class="col-md-3">
                                    <p class="text-muted small mb-1 text-uppercase fw-bold opacity-50">Teslimat Adresi</p>
                                    <p class="mb-0 text-muted text-truncate" title="@order.AddressLine" style="max-width: 250px;">@order.AddressLine</p>
                                </div>
                                <div class="col-md-2">
                                    <p class="text-muted small mb-1 text-uppercase fw-bold opacity-50">Toplam Tutar</p>
                                    <h6 class="mb-0 fw-bold">@order.TotalPrice.ToString("C2")</h6>
                                    @if(order.Discount > 0)
                                    {
                                        <div class="text-success-glow smaller mt-1 animate-pulse" style="font-size: 0.75rem;">
                                            <i class="bi bi-tag-fill me-1"></i> -@order.Discount.ToString("C2") (@order.CouponCode)
                                        </div>
                                    }
                                </div>
                                <div class="col-md-2">
                                    <p class="text-muted small mb-1 text-uppercase fw-bold opacity-50">Durum</p>
                                    <span class="badge @order.Status.ToStatusClass() rounded-pill px-3 py-2 border border">
                                        @order.Status.ToStatusText()
                                    </span>
                                </div>
                            </div>
                            
                            <div class="mt-4 pt-3 border-top border d-flex justify-content-between align-items-center">
                                <div class="d-flex gap-2">
                                    @foreach(var item in order.OrderItems.Take(4))
                                    {
                                        <div class="rounded-3 bg-light p-1 border border" style="width: 45px; height: 45px;">
                                            @if(!string.IsNullOrEmpty(item.ImageUrl))
                                            {
                                                <img src="@CatalogService.GetFullImageUrl(item.ImageUrl)" 
                                                     class="w-100 h-100 object-fit-cover rounded-2" 
                                                     title="@item.ProductName" />
                                            }
                                            else
                                            {
                                                <div class="w-100 h-100 d-flex align-items-center justify-content-center">
                                                    <i class="bi bi-box-seam text-muted opacity-25"></i>
                                                </div>
                                            }
                                        </div>
                                    }
                                    @if(order.OrderItems.Count > 4)
                                    {
                                        <div class="rounded-3 bg-light d-flex align-items-center justify-content-center text-muted smaller px-2" style="height: 45px;">
                                            +@(order.OrderItems.Count - 4)
                                        </div>
                                    }
                                </div>
                                <button class="btn btn-outline-primary px-4 py-2" @onclick='() => Nav.NavigateTo($"/order-detail/{order.Id}")' style="border-radius: 12px; border: 1px solid rgba(99, 102, 241, 0.3);">
                                    Detayları Gör <i class="bi bi-chevron-right ms-1"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .order-card:hover {
        transform: translateY(-5px);
        background: #F8F8F8 !important;
        border-color: var(--border-color) !important;
        box-shadow: 0 15px 35px rgba(0,0,0,0.4) !important;
    }
</style>

@code {
    private List<OrderDto>? orders;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var authToken = await LocalStore.GetItemAsync<string>("authToken");
        var userName = await LocalStore.GetItemAsync<string>("userName");

        if (string.IsNullOrEmpty(authToken) || string.IsNullOrEmpty(userName))
        {
            Nav.NavigateTo("/login");
            return;
        }

        isLoading = true;
        try
        {
            orders = await OrderService.GetOrders(authToken, userName);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Sipariş yükleme hatası: {ex.Message}");
            ToastService.Notify("Siparişleriniz yüklenirken bir bağlantı hatası oluştu.", ToastLevel.Error);
            orders = new();
        }
        finally
        {
            isLoading = false;
        }
    }
}

@page "/my-orders"
@using WebUI.Services
@using Common.DTOs
@inject OrderService OrderService
@inject Blazored.LocalStorage.ILocalStorageService LocalStore
@inject NavigationManager Nav
@inject ToastService ToastService

<div class="container mt-5 pt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">Sipariş Geçmişim</h2>
        <button class="btn btn-outline-secondary btn-sm" @onclick='() => Nav.NavigateTo("/")'>
            <i class="bi bi-arrow-left"></i> Alışverişe Dön
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
            <p class="mt-3 text-muted">Siparişleriniz yükleniyor...</p>
        </div>
    }
    else if (orders == null || !orders.Any())
    {
        <div class="card border-0 shadow-sm text-center py-5" style="border-radius: 20px;">
            <div class="card-body">
                <i class="bi bi-bag-x text-muted mb-3" style="font-size: 4rem;"></i>
                <h4 class="fw-bold">Henüz hiç siparişiniz yok.</h4>
                <p class="text-muted">En sevdiğiniz ürünleri hemen keşfetmeye başlayın!</p>
                <button class="btn btn-primary px-4 py-2 mt-2" @onclick='() => Nav.NavigateTo("/")' style="border-radius: 12px;">
                    Alışverişe Başla
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var order in orders)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm order-card" style="border-radius: 20px; transition: transform 0.2s;">
                        <div class="card-body p-4">
                            <div class="row align-items-center">
                                <div class="col-md-3">
                                    <p class="text-muted small mb-1 text-uppercase fw-bold">Sipariş Tarihi</p>
                                    <h6 class="mb-0">@order.CreatedDate.ToString("dd MMMM yyyy HH:mm")</h6>
                                </div>
                                <div class="col-md-2">
                                    <p class="text-muted small mb-1 text-uppercase fw-bold">Sipariş No</p>
                                    <h6 class="mb-0 text-primary">#ORD-@order.Id.ToString("D5")</h6>
                                </div>
                                <div class="col-md-3">
                                    <p class="text-muted small mb-1 text-uppercase fw-bold">Teslimat Adresi</p>
                                    <p class="mb-0 text-truncate" title="@order.AddressLine" style="max-width: 200px;">@order.AddressLine</p>
                                </div>
                                <div class="col-md-2">
                                    <p class="text-muted small mb-1 text-uppercase fw-bold">Toplam Tutar</p>
                                    <h6 class="mb-0 fw-bold">@order.TotalPrice.ToString("C2")</h6>
                                </div>
                                <div class="col-md-2 text-md-end pt-3 pt-md-0">
                                    <button class="btn btn-outline-primary px-4" @onclick='() => Nav.NavigateTo($"/order-detail/{order.Id}")' style="border-radius: 12px;">
                                        Detay
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .order-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>

@code {
    private List<OrderDto>? orders;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var authToken = await LocalStore.GetItemAsync<string>("authToken");
        var userName = await LocalStore.GetItemAsync<string>("userName");

        if (string.IsNullOrEmpty(authToken) || string.IsNullOrEmpty(userName))
        {
            Nav.NavigateTo("/login");
            return;
        }

        isLoading = true;
        try
        {
            orders = await OrderService.GetOrders(authToken, userName);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Sipariş yükleme hatası: {ex.Message}");
            ToastService.Notify("Siparişleriniz yüklenirken bir bağlantı hatası oluştu.", ToastLevel.Error);
            orders = new();
        }
        finally
        {
            isLoading = false;
        }
    }
}

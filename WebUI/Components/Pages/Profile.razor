@page "/profile"
@using WebUI.Services
@using Common.DTOs
@inject AuthService AuthService
@inject Blazored.LocalStorage.ILocalStorageService LocalStore
@inject NavigationManager Nav
@inject ToastService ToastService
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<div class="auth-page py-5 animate-fade-in">
    <div class="profile-wrap">

        @if (isLoading)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-dark mb-3"></div>
                <p class="text-muted">Profil yükleniyor...</p>
            </div>
        }
        else
        {
            <!-- Avatar Header -->
            <div class="profile-hero mb-4">
                <div class="profile-avatar">
                    <span>@(userProfile?.UserName?.Substring(0, 1).ToUpper() ?? "?")</span>
                </div>
                <div>
                    <h3 class="fw-bold mb-0" style="letter-spacing:-0.04em;">@userProfile?.UserName</h3>
                    <span class="role-badge">@userProfile?.Role</span>
                </div>
            </div>

            <!-- Hesap Bilgileri -->
            <div class="auth-card mb-4">
                <h5 class="profile-section-title"><i class="bi bi-person-fill me-2"></i>Hesap Bilgileri</h5>
                <div class="mb-3">
                    <label class="auth-label">Kullanıcı Adı</label>
                    <div class="auth-input-wrap">
                        <i class="bi bi-person auth-input-icon"></i>
                        <input type="text" class="auth-input" value="@userProfile?.UserName" disabled />
                    </div>
                </div>
                <div class="mb-4">
                    <label class="auth-label">E-posta Adresi</label>
                    <div class="auth-input-wrap">
                        <i class="bi bi-envelope auth-input-icon"></i>
                        <input type="email" class="auth-input" @bind="updateDto.Email" placeholder="E-posta adresiniz" />
                    </div>
                </div>
                <button class="btn btn-primary w-100 py-2" @onclick="HandleUpdateProfile" disabled="@isSaving">
                    @if (isSaving) { <span class="spinner-border spinner-border-sm me-2"></span> }
                    Bilgileri Güncelle
                </button>
            </div>

            <!-- Şifre Değiştirme -->
            <div class="auth-card">
                <h5 class="profile-section-title"><i class="bi bi-shield-lock-fill me-2"></i>Şifre Değiştir</h5>
                <div class="mb-3">
                    <label class="auth-label">Yeni Şifre</label>
                    <div class="auth-input-wrap">
                        <i class="bi bi-lock auth-input-icon"></i>
                        <input type="password" class="auth-input" @bind="updateDto.NewPassword" placeholder="Boş bırakırsanız değişmez" />
                    </div>
                </div>
                <div class="mb-4">
                    <label class="auth-label">Yeni Şifre (Tekrar)</label>
                    <div class="auth-input-wrap">
                        <i class="bi bi-lock-fill auth-input-icon"></i>
                        <input type="password" class="auth-input" @bind="confirmPassword" placeholder="Şifreyi onaylayın" />
                    </div>
                </div>
                <button class="btn btn-outline-dark w-100 py-2" @onclick="HandleUpdatePassword" disabled="@isSaving">
                    Şifreyi Değiştir
                </button>
            </div>
        }

    </div>
</div>

@code {
    private UserProfileDto? userProfile;
    private UpdateProfileDto updateDto = new();
    private string confirmPassword = "";
    private bool isLoading = true;
    private bool isSaving = false;

    protected override async Task OnInitializedAsync()
    {
        var userName = await LocalStore.GetItemAsync<string>("userName");
        if (string.IsNullOrEmpty(userName))
        {
            Nav.NavigateTo("/login");
            return;
        }

        userProfile = await AuthService.GetProfile(userName);
        if (userProfile != null)
        {
            updateDto.Email = userProfile.Email;
        }
        isLoading = false;
    }

    private async Task HandleUpdateProfile()
    {
        if (userProfile == null) return;

        isSaving = true;
        var success = await AuthService.UpdateProfile(userProfile.UserName, new UpdateProfileDto { Email = updateDto.Email });

        if (success)
            ToastService.Notify("Profil başarıyla güncellendi!", ToastLevel.Success);
        else
            ToastService.Notify("Güncelleme sırasında bir hata oluştu.", ToastLevel.Error);

        isSaving = false;
    }

    private async Task HandleUpdatePassword()
    {
        if (userProfile == null) return;

        if (string.IsNullOrWhiteSpace(updateDto.NewPassword))
        {
            ToastService.Notify("Lütfen yeni bir şifre girin.", ToastLevel.Warning);
            return;
        }

        if (updateDto.NewPassword != confirmPassword)
        {
            ToastService.Notify("Şifreler uyuşmuyor!", ToastLevel.Error);
            return;
        }

        isSaving = true;
        var success = await AuthService.UpdateProfile(userProfile.UserName, new UpdateProfileDto
        {
            Email = updateDto.Email,
            NewPassword = updateDto.NewPassword
        });

        if (success)
        {
            ToastService.Notify("Şifreniz başarıyla güncellendi!", ToastLevel.Success);
            updateDto.NewPassword = "";
            confirmPassword = "";
        }
        else
        {
            ToastService.Notify("Şifre güncellenirken bir hata oluştu.", ToastLevel.Error);
        }
        isSaving = false;
    }
}

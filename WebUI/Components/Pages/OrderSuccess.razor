@page "/order-success"
@inject NavigationManager Nav

<div class="container d-flex flex-column align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="text-center p-5 shadow-sm border-0" style="border-radius: 30px; background: white; max-width: 500px;">
        <div class="mb-4">
            <div class="display-1 text-success pulse">
                <i class="bi bi-check-circle-fill"></i>
            </div>
        </div>
        
        <h2 class="fw-bold mb-3">Siparişiniz Alındı! 🎉</h2>
        <p class="text-muted mb-4 px-4">
            Harika bir seçim yaptınız. Siparişiniz başarıyla işleme alındı ve hazırlık aşamasına geçildi. Tüm detaylar e-posta adresinize gönderildi.
        </p>

        <div class="d-grid gap-2">
            <button class="btn btn-primary btn-lg py-3" style="border-radius: 15px;" @onclick='() => Nav.NavigateTo("/")'>
                Alışverişe Devam Et
            </button>
            <button class="btn btn-outline-secondary py-3" style="border-radius: 15px;" @onclick='() => Nav.NavigateTo("/my-orders")'>
                Siparişlerimi Gör
            </button>
        </div>
    </div>
</div>

<style>
    .pulse {
        animation: pulse-animation 2s infinite;
    }
    @@keyframes pulse-animation {
        0% { transform: scale(1); }
        50% { transform: scale(1.05); }
        100% { transform: scale(1); }
    }
</style>
@page "/order-success"
@using Microsoft.AspNetCore.Components
@inject NavigationManager Nav

<div class="container d-flex flex-column align-items-center justify-content-center animate-fade-in" style="min-height: 80vh;">
    <div class="glass-card p-5 text-center animate-up" style="max-width: 600px; border-radius: 40px;">
        <div class="mb-5">
            <div class="success-icon-wrapper pulse shadow-glow mx-auto">
                <i class="bi bi-check-lg"></i>
            </div>
        </div>
        
        <h1 class="display-5 fw-black mb-3 text-gradient">Siparişiniz Alındı! 🎉</h1>
        <p class="text-muted mb-4 px-lg-4 fs-5">
            Harika bir seçim yaptınız. Siparişiniz başarıyla işleme alındı ve hazırlık aşamasına geçildi.
        </p>

        @if (!string.IsNullOrEmpty(TransactionId))
        {
            <div class="mb-5 p-4 glass-card bg-white bg-opacity-10 border-dashed" style="border-color: var(--primary-glow);">
                <div class="small text-white opacity-75 text-uppercase fw-bold mb-2">Ödeme İşlem Numarası</div>
                <div class="font-monospace text-primary-glow fs-4 fw-bold">@TransactionId</div>
            </div>
        }

        <div class="d-grid gap-3">
            <button class="btn btn-primary btn-lg py-3 fw-bold rounded-4 shadow-glow" @onclick='() => Nav.NavigateTo("/")'>
                Alışverişe Devam Et <i class="bi bi-arrow-right-short ms-1"></i>
            </button>
            <button class="btn btn-outline-white-glass py-3 fw-bold rounded-4" @onclick='() => Nav.NavigateTo("/my-orders")'>
                Siparişlerimi Takip Et
            </button>
        </div>
        <div class="mt-5 opacity-50">
            <small>Bizi tercih ettiğiniz için teşekkürler.</small>
        </div>
    </div>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? TransactionId { get; set; }
}

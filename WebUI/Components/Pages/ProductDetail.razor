@page "/product/{id}"
@using Common.DTOs
@using WebUI.Services
@inject CatalogService CatalogService
@inject BasketService BasketService
@inject OrderService OrderService
@inject Blazored.LocalStorage.ILocalStorageService LocalStore
@inject NavigationManager NavigationManager
@inject ToastService ToastService

@if (product == null)
{
    <div class="loader-fullscreen">
        <div class="spinner-border text-primary shadow-glow" role="status"></div>
        <p class="mt-3 text-muted">Ürün hazırlanıyor...</p>
    </div>
}
else
{
    <div class="product-detail-page animate-fade-in">
        <div class="container pt-4 pb-5">
            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb glass-breadcrumb px-3 py-2 rounded-pill">
                    <li class="breadcrumb-item"><a href="/">Ana Sayfa</a></li>
                    <li class="breadcrumb-item active text-white">@product.Name</li>
                </ol>
            </nav>

            <div class="row g-5">
                <!-- Görsel ve Teknik Özellikler -->
                <div class="col-lg-6">
                    <div class="glass-card product-main-img-card overflow-hidden mb-4">
                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                        {
                            <img src="@CatalogService.GetFullImageUrl(product.ImageUrl)" class="img-fluid w-100 detail-img" alt="@product.Name">
                        }
                        else
                        {
                            <div class="detail-placeholder">
                                <i class="bi bi-cpu-fill"></i>
                            </div>
                        }
                    </div>

                    @if (product.Features != null && product.Features.Any())
                    {
                        <div class="glass-card p-4 animate-up">
                            <h5 class="fw-bold mb-3 text-gradient">Teknik Özellikler</h5>
                            <div class="row g-3">
                                @foreach (var feature in product.Features)
                                {
                                    <div class="col-md-6">
                                        <div class="feature-item">
                                            <i class="bi bi-chevron-right text-primary me-2"></i>
                                            <span>@feature</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>

                <!--  Bilgiler, Fiyat, İşlemler -->
                <div class="col-lg-6">
                    <div class="product-info-sticky">
                        <span class="badge category-badge-premium mb-3">@product.Category</span>
                        <h1 class="display-5 fw-bold mb-3">@product.Name</h1>
                        
                        <div class="d-flex align-items-center mb-4 pb-2 border-bottom border-white border-opacity-10">
                            <div class="rating-box-premium me-3">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    var starIndex = i;
                                    <i class="bi @(starIndex <= (hoverRating > 0 ? hoverRating : product.Rating) ? "bi-star-fill text-warning" : "bi-star text-muted") @(hasBought ? "cursor-pointer" : "") fs-5 me-1"
                                       @onmouseover="() => { if(hasBought) hoverRating = starIndex; }"
                                       @onmouseout="() => { if(hasBought) hoverRating = 0; }"
                                       @onclick="() => { if(hasBought) RateProduct(starIndex); }"></i>
                                }
                            </div>
                            <span class="text-muted small">@product.Rating.ToString("F1") (@product.ReviewCount Değerlendirme)</span>
                        </div>

                        <div class="price-section-premium mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <small class="text-muted">Peşin Fiyatına 9 Taksit</small>
                                <div class="stock-status-pill">
                                    @if (product.StockQuantity > 10)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-10 px-3 py-2">
                                            <i class="bi bi-check-circle-fill me-1"></i> Stokta Var
                                        </span>
                                    }
                                    else if (product.StockQuantity > 0)
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-10 px-3 py-2 animate-pulse">
                                            <i class="bi bi-exclamation-triangle-fill me-1"></i> Son @product.StockQuantity Adet!
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-10 px-3 py-2">
                                            <i class="bi bi-x-circle-fill me-1"></i> Tükendi
                                        </span>
                                    }
                                </div>
                            </div>
                            <h2 class="display-6 fw-bold text-gradient">@product.Price.ToString("C2")</h2>
                        </div>

                        <p class="product-description-premium mb-5">@product.Description</p>

                        <div class="d-grid gap-3 mb-5">
                            @if (product.StockQuantity > 0)
                            {
                                <button class="btn btn-primary btn-lg premium-action-btn" @onclick="AddToCart" disabled="@isAdding">
                                    @if (isAdding)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span> <span>Sepete Ekleniyor...</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-cart-plus-fill me-2"></i> <span>Sepete Ekle</span>
                                    }
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-secondary btn-lg rounded-4 opacity-50" disabled>
                                    <i class="bi bi-x-circle me-2"></i> Stokta Yok
                                </button>
                            }
                            <button class="btn btn-outline-light btn-lg rounded-4 opacity-75" @onclick='@(() => NavigationManager.NavigateTo("/"))'>
                                <i class="bi bi-arrow-left me-2"></i> Keşfe Devam Et
                            </button>
                        </div>

                        <div class="row g-3">
                            <div class="col-4">
                                <div class="info-pill-glass">
                                    <i class="bi bi-truck mb-2"></i>
                                    <span>Hızlı Teslimat</span>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="info-pill-glass">
                                    <i class="bi bi-shield-check mb-2"></i>
                                    <span>2 Yıl Garanti</span>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="info-pill-glass">
                                    <i class="bi bi-arrow-repeat mb-2"></i>
                                    <span>Kolay İade</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Comments Section -->
            <div class="mt-5 pt-5 border-top border-white border-opacity-10">
                <div class="row">
                    <div class="col-lg-8 mx-auto">
                        <div class="d-flex justify-content-between align-items-center mb-5">
                            <h3 class="fw-bold mb-0">Müşteri Deneyimleri</h3>
                            @if (hasBought)
                            {
                                <button class="btn btn-sm btn-outline-primary rounded-pill px-4" @onclick="() => showCommentForm = !showCommentForm">
                                    @(showCommentForm ? "Vazgeç" : "Yorum Yap")
                                </button>
                            }
                        </div>

                        @if (showCommentForm && hasBought)
                        {
                            <div class="glass-card p-4 mb-5 animate-up">
                                <h6 class="fw-bold mb-3 small">Yorumunuzu Paylaşın (@userName)</h6>
                                <textarea @bind="newComment.Content" class="form-control glass-input mb-3" rows="3" placeholder="Ürün beklentilerinizi karşıladı mı?"></textarea>
                                <div class="text-end">
                                    <button class="btn btn-primary btn-sm px-5" @onclick="SubmitComment" disabled="@isSubmittingComment">
                                        @if(isSubmittingComment) { <span class="spinner-border spinner-border-sm me-2"></span> }
                                        Gönder
                                    </button>
                                </div>
                            </div>
                        }

                        @if (comments == null)
                        {
                            <div class="text-center py-5">
                                <div class="spinner-border text-primary spinner-border-sm"></div>
                            </div>
                        }
                        else if (!comments.Any())
                        {
                            <div class="text-center py-5 glass-card opacity-50">
                                <i class="bi bi-chat-dots mb-3 d-block fs-1"></i>
                                <p class="mb-0">Henüz yorum yapılmamış.</p>
                            </div>
                        }
                        else
                        {
                            <div class="comment-list d-flex flex-column gap-3">
                                @foreach (var comment in comments)
                                {
                                    <div class="glass-card p-4 comment-item-premium">
                                        <div class="d-flex justify-content-between mb-3">
                                            <div class="d-flex align-items-center">
                                                <div class="user-avatar-comment me-3">@comment.UserName[0].ToString().ToUpper()</div>
                                                <div>
                                                    <h6 class="mb-0 fw-bold">@comment.UserName</h6>
                                                    <small class="text-muted">Doğrulanmış Alıcı</small>
                                                </div>
                                            </div>
                                            <span class="text-muted small">@comment.CreatedDate.ToLocalTime().ToString("dd MMM yyyy")</span>
                                        </div>
                                        <p class="mb-0 text-white text-opacity-75">@comment.Content</p>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}



@code {
    [Parameter] public string Id { get; set; } = string.Empty;
    private ProductDto? product;
    private bool isAdding = false;
    private int hoverRating = 0;
    private List<CommentDto> comments;
    private CommentDto newComment = new();
    private bool isSubmittingComment = false;
    private string userName = "";
    private bool hasBought = false;
    private bool showCommentForm = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadProduct();
        await CheckUserStatus();
    }

    private async Task CheckUserStatus()
    {
        var token = await LocalStore.GetItemAsync<string>("authToken");
        userName = await LocalStore.GetItemAsync<string>("userName") ?? "";

        if (!string.IsNullOrEmpty(token) && !string.IsNullOrEmpty(userName))
        {
            hasBought = await OrderService.CheckPurchase(token, userName, Id);
            newComment.UserName = userName; // İsmi otomatik set et
        }
    }

    private async Task LoadProduct()
    {
        product = await CatalogService.GetProductById(Id);
        if (product != null)
        {
            comments = await CatalogService.GetComments(Id);
        }
    }

    private async Task RateProduct(int score)
    {
        if (!hasBought)
        {
            ToastService.Notify("Puan vermek için ürünü satın almalısınız.", ToastLevel.Warning);
            return;
        }

        var result = await CatalogService.RateProduct(Id, score);
        if (result != null)
        {
            product.Rating = result.Rating;
            product.ReviewCount = result.ReviewCount;
            ToastService.Notify($"{score} yıldız verdiniz!", ToastLevel.Success);
        }
    }

    private async Task SubmitComment()
    {
        if (string.IsNullOrWhiteSpace(newComment.Content))
        {
            ToastService.Notify("Lütfen yorumunuzu yazın.", ToastLevel.Warning);
            return;
        }

        isSubmittingComment = true;
        var success = await CatalogService.AddComment(Id, newComment);
        if (success)
        {
            newComment = new() { UserName = userName };
            comments = await CatalogService.GetComments(Id);
            ToastService.Notify("Yorumunuz eklendi.", ToastLevel.Success);
        }
        isSubmittingComment = false;
    }

    private async Task AddToCart()
    {
        if (product == null || isAdding) return;

        var token = await LocalStore.GetItemAsync<string>("authToken");
        var user = await LocalStore.GetItemAsync<string>("userName");

        if (string.IsNullOrEmpty(token) || string.IsNullOrEmpty(user))
        {
            user = await LocalStore.GetItemAsync<string>("guestId");
            if (string.IsNullOrEmpty(user))
            {
                user = "guest-" + Guid.NewGuid().ToString().Substring(0, 8);
                await LocalStore.SetItemAsync("guestId", user);
            }
            token = string.Empty;
        }

        isAdding = true;
        StateHasChanged();

        try
        {
            var result = await BasketService.AddItem(token, user, product);
            if (result.Success)
            {
                ToastService.Notify($"{product.Name} sepete eklendi.", ToastLevel.Success);
                NavigationManager.NavigateTo("/basket");
            }
            else
            {
                ToastService.Notify($"Hata: {result.Message}", ToastLevel.Error);
            }
        }
        catch (Exception ex)
        {
            ToastService.Notify($"Hata: {ex.Message}", ToastLevel.Error);
        }
        finally
        {
            isAdding = false;
            StateHasChanged();
        }
    }
}

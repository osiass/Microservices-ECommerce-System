{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "ReverseProxy": {
        "Routes": {
            "images_route": {
                "ClusterId": "catalog_cluster",
                "Order": 0,
                "Match": {
                    "Path": "/images/{**remainder}"
                }
            },
            "catalog_route": {
                "ClusterId": "catalog_cluster",
                "Order": 1,
                "Match": {
                    "Path": "/catalog/{**remainder}"
                },
                "Transforms": [
                    {
                        "PathRemovePrefix": "/catalog"
                    }
                ]
            },
            "discount_route": {
                "ClusterId": "discount_cluster",
                "Order": 2,
                "Match": {
                    "Path": "/discount/{**remainder}"
                },
                "Transforms": [
                    {
                        "PathRemovePrefix": "/discount"
                    }
                ]
            },
            "basket_route": {
                "ClusterId": "basket_cluster",
                "Order": 3,
                "Match": {
                    "Path": "/basket/{**remainder}"
                },
                "Transforms": [
                    {
                        "PathRemovePrefix": "/basket"
                    }
                ]
            },
            "identity_route": {
                "ClusterId": "identity_cluster",
                "Order": 4,
                "Match": {
                    "Path": "/identity/{**remainder}"
                },
                "Transforms": [
                    {
                        "PathRemovePrefix": "/identity"
                    }
                ]
            },
            "order_route": {
                "ClusterId": "order_cluster",
                "Order": 5,
                "Match": {
                    "Path": "/order/{**remainder}"
                },
                "Transforms": [
                    {
                        "PathRemovePrefix": "/order"
                    }
                ]
            },
            "webui_route": {
                "ClusterId": "webui_cluster",
                "Order": 100,
                "Match": {
                    "Path": "/{**remainder}"
                }
            },
            "inventory_route": {
                "ClusterId": "inventory_cluster",
                "Order": 6,
                "Match": {
                    "Path": "/inventory/{**remainder}"
                },
                "Transforms": [
                    {
                        "PathRemovePrefix": "/inventory"
                    }
                ]
            }
        },
        "Clusters": {
            "catalog_cluster": {
                "Destinations": {
                    "destination1": {
                        "Address": "http://catalog-api:8080"
                    }
                }
            },
            "discount_cluster": {
                "Destinations": {
                    "destination1": {
                        "Address": "http://discount-api:8080"
                    }
                }
            },
            "basket_cluster": {
                "Destinations": {
                    "destination1": {
                        "Address": "http://basket-api:8080"
                    }
                }
            },
            "identity_cluster": {
                "Destinations": {
                    "destination1": {
                        "Address": "http://identity-api:8080"
                    }
                }
            },
            "order_cluster": {
                "Destinations": {
                    "destination1": {
                        "Address": "http://order-api:8080"
                    }
                }
            },
            "inventory_cluster": {
                "Destinations": {
                    "destination1": {
                        "Address": "http://inventory-api:8080"
                    }
                }
            },
            "webui_cluster": {
                "Destinations": {
                    "destination1": {
                        "Address": "http://web-ui:8080"
                    }
                }
            }
        }
    }
}